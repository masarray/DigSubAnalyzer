<Window x:Class="ProcessBus.App.Wpf.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Process Bus Insight"
        Width="960"
        Height="620"
        MinWidth="880"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#07111D"
        Icon="/IEC61850.PNG"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#0B1A2A"/>
        <SolidColorBrush x:Key="PanelAltBrush" Color="#0D2033"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#294864"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#6ED2FF"/>
        <SolidColorBrush x:Key="TextBrush" Color="#EAF6FF"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#9AB2C7"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="BodyStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D6E8F8"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="LineHeight" Value="20"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="LinkButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#0E6AC0"/>
            <Setter Property="BorderBrush" Value="#429FE8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="13,8"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1A78C8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#0B4F8B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#091725"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="14"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Width="58" Height="58" CornerRadius="12" Background="#102A43" BorderBrush="#26577D" BorderThickness="1">
                    <Image Source="/Views/Assets/Icons/IEC61850.PNG" Stretch="Uniform" Margin="7"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Process Bus Insight" Foreground="{StaticResource TextBrush}" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="Receive-only IEC 61850 Process Bus evidence analyzer"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="12.5"
                               Margin="0,3,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock x:Name="VersionText" Text="Version" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                    <TextBlock x:Name="BuildText" Text="Build" Foreground="{StaticResource MutedBrush}" FontSize="11.5" Margin="0,3,0,0" HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.65*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Engineering purpose" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Style="{StaticResource BodyStyle}"
                                       Text="Process Bus Insight observes, decodes, visualizes, replays, and compares IEC 61850 Sampled Values, GOOSE, PTP timing context, and SCL evidence. It is designed to support authorized FAT, SAT, commissioning, laboratory, interoperability, and troubleshooting work."/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Evidence boundary" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Style="{StaticResource BodyStyle}">
                                <Run Text="The application can document configured expectations, frames observed at the selected capture or replay point, and its own decoding and calculations. "/>
                                <Run FontWeight="SemiBold" Text="It does not by itself prove formal conformance, calibrated timing, deterministic real-time operation, functional safety, cybersecurity approval, switching authority, or that an external IED accepted or acted on traffic."/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Operational boundary" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Style="{StaticResource BodyStyle}"
                                       Text="The product is receive-only. It does not publish Sampled Values or GOOSE and does not send IEC 61850 control commands. Use only an authorized TAP, mirror port, engineering switch, or isolated test network."/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Licensing" Style="{StaticResource SectionTitleStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="112"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Community" Foreground="{StaticResource MutedBrush}" Margin="0,0,8,8"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="GPL-3.0-or-later" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="1" Text="Historical" Foreground="{StaticResource MutedBrush}" Margin="0,0,8,8"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="Apache-2.0 through the recorded boundary only" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="2" Text="Commercial" Foreground="{StaticResource MutedBrush}" Margin="0,0,8,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="Separate negotiated and executed agreement" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                            </Grid>
                            <TextBlock Style="{StaticResource BodyStyle}" FontSize="11.5" Margin="0,12,0,0"
                                       Text="COMMERCIAL-LICENSE.md is an invitation to negotiate and grants no additional rights by itself. The community software is provided without warranty to the extent permitted by the GNU GPL."/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Background="{StaticResource PanelAltBrush}">
                        <StackPanel>
                            <TextBlock Text="Project and legal resources" Style="{StaticResource SectionTitleStyle}"/>
                            <WrapPanel>
                                <Button Style="{StaticResource LinkButtonStyle}" Content="Repository" Click="OpenRepository_Click"/>
                                <Button Style="{StaticResource LinkButtonStyle}" Content="GPL License" Click="OpenLicense_Click"/>
                                <Button Style="{StaticResource LinkButtonStyle}" Content="Commercial" Click="OpenCommercial_Click"/>
                                <Button Style="{StaticResource LinkButtonStyle}" Content="Third-party" Click="OpenThirdParty_Click"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Copyright" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Style="{StaticResource BodyStyle}" FontSize="11.5"
                                       Text="Copyright (C) 2026 Ari Sulistiono and Process Bus Insight Contributors. Project names and branding are governed separately from the software copyright license."/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="2" Background="#091725" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Foreground="{StaticResource MutedBrush}"
                           VerticalAlignment="Center"
                           Text="Inspect evidence carefully. Final engineering acceptance remains project- and authority-specific."/>
                <Button Grid.Column="1" Content="Close" Width="110" Height="34" HorizontalAlignment="Right" IsDefault="True" Click="Close_Click" Style="{StaticResource LinkButtonStyle}" Margin="0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
