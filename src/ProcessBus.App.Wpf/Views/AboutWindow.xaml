<Window x:Class="ProcessBus.App.Wpf.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="About Process Bus Insight"
        Height="560"
        Width="940"
        MinWidth="860"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="#07111D"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Icon="/IEC61850.PNG">
    <Window.Resources>
        <SolidColorBrush x:Key="BgMain" Color="#07111D"/>
        <SolidColorBrush x:Key="CardBg" Color="#0B1A2A"/>
        <SolidColorBrush x:Key="Accent" Color="#6ED2FF"/>
        <SolidColorBrush x:Key="TextMain" Color="#EAF6FF"/>
        <SolidColorBrush x:Key="TextSub" Color="#D6E8F8"/>
        <SolidColorBrush x:Key="TextMuted" Color="#8FAAC3"/>
        <SolidColorBrush x:Key="BorderSoft" Color="#294864"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="BodyTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSub}"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="22"/>
        </Style>

        <Style x:Key="ValueChipBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>

        <Style x:Key="LabelMiniStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="ValueMiniStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <SolidColorBrush x:Key="ScrollTrackBrush" Color="#0B1220"/>
        <SolidColorBrush x:Key="ScrollThumbBrush" Color="#334155"/>
        <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#6ED2FF"/>
        <SolidColorBrush x:Key="ScrollThumbPressedBrush" Color="#0E6AC0"/>

        <Style x:Key="MinimalScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Background="{StaticResource ScrollThumbBrush}"
                                CornerRadius="5"
                                Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource ScrollThumbHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource ScrollThumbPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="VerticalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Background="{StaticResource ScrollTrackBrush}" Width="12">
                <Track x:Name="PART_Track" IsDirectionReversed="True">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageUpCommand"
                                      Opacity="0"
                                      IsTabStop="False"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource MinimalScrollBarThumbStyle}"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageDownCommand"
                                      Opacity="0"
                                      IsTabStop="False"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <ControlTemplate x:Key="HorizontalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Background="{StaticResource ScrollTrackBrush}" Height="12">
                <Track x:Name="PART_Track">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageLeftCommand"
                                      Opacity="0"
                                      IsTabStop="False"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource MinimalScrollBarThumbStyle}"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageRightCommand"
                                      Opacity="0"
                                      IsTabStop="False"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{StaticResource ScrollTrackBrush}"/>
            <Setter Property="Width" Value="12"/>
            <Setter Property="Template" Value="{StaticResource VerticalScrollBarTemplate}"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="12"/>
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Template" Value="{StaticResource HorizontalScrollBarTemplate}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TactileButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#0E6AC0"/>
            <Setter Property="BorderBrush" Value="#1C5F91"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>

                            <Border x:Name="BtnBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1">

                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="2"
                                              BlurRadius="6"
                                              Opacity="0.4"/>
                                </Border.Effect>

                                <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="4"/>
                            </Border>

                        </Grid>

                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder"
                                Property="Background"
                                Value="#1C5F91"/>
                            </Trigger>

                            <!-- Pressed -->
                            <Trigger Property="IsPressed" Value="True">

                                <Setter TargetName="BtnBorder"
                                Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="1"/>
                                    </Setter.Value>
                                </Setter>

                                <Setter TargetName="BtnBorder"
                                Property="Background"
                                Value="#0E2032"/>

                                <Setter TargetName="BtnBorder"
                                Property="Effect"
                                Value="{x:Null}"/>

                            </Trigger>

                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="BtnBorder"
                                Property="Opacity"
                                Value="0.5"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BgMain}" Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="96"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="58"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,6"
                Padding="10,8"
                Background="#0B1A2A"
                BorderBrush="#294864"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Height="55" CornerRadius="12" Background="Transparent" VerticalAlignment="Center" Margin="1,0,10,0">
                    <Image Source="/Views/Assets/Icons/IEC61850.PNG"
                           Stretch="Uniform"
                           Margin="4"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0">
                    <TextBlock Text="Process Bus Analyzer (SV &amp; GOOSE)"
                               Foreground="{StaticResource TextMain}"
                               FontSize="17"
                               FontWeight="SemiBold"/>
                    <TextBlock TextWrapping="Wrap"
                               Text="IEC 61850 Process Bus engineering tool for SV/GOOSE/PTP visibility, FAT/SAT validation, commissioning, and real-time troubleshooting"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="12.5"/>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="18,0,0,0">
                    <TextBlock Text="Version 1.0.0"
                               Foreground="{StaticResource TextMain}"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Right"/>
                    <TextBlock Text="Build 2026.04"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="12"
                               HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="16,10,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.6*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,12,0">
                <StackPanel Margin="0,0,8,0">
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="About This Software" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Style="{StaticResource BodyTextStyle}">
Process Bus Analyzer is a field-oriented digital instrumentation platform for IEC 61850 Process Bus analysis.

It provides real-time visibility of Sampled Values (SV) and GOOSE communication by combining waveform analysis, phasor visualization, protocol inspection, diagnostic indicators, and event logs in one practical engineering interface.

Designed to complement conventional test equipment, it brings oscilloscope-level visibility into digital substation communication so engineers can move from guessing to evidence-based troubleshooting.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Engineering Purpose" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Style="{StaticResource BodyTextStyle}" Margin="0,0,0,8"
                                       Text="Improve SV / GOOSE visibility during FAT, SAT, commissioning, and troubleshooting"/>
                            <TextBlock Style="{StaticResource BodyTextStyle}" Margin="0,0,0,8"
                                       Text="Help engineers detect timing, quality, packet, and communication anomalies earlier"/>
                            <TextBlock Style="{StaticResource BodyTextStyle}" Margin="0,0,0,8"
                                       Text="Reduce blind trial-and-error during protocol investigation and system validation"/>
                            <TextBlock Style="{StaticResource BodyTextStyle}"
                                       Text="Bridge power system engineering, network diagnostics, and IEC 61850 analysis"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Why It Matters" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Style="{StaticResource BodyTextStyle}">
In real substation projects, the most expensive issues are often not caused by one obvious failure, but by small timing, configuration, quality, and communication symptoms that appear late in the test cycle. This tool is designed to surface those symptoms earlier, so engineering decisions can be made with clearer evidence.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Open Source License" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Style="{StaticResource BodyTextStyle}">
Process Bus Insight source code is licensed under Apache-2.0. The analyzer remains receive-only and raw-passive: it does not link to external IEC 61850 subscriber stacks in the WPF product runtime.
                            </TextBlock>

                            <Border Style="{StaticResource ValueChipBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Source" Style="{StaticResource LabelMiniStyle}" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Apache-2.0" Style="{StaticResource ValueMiniStyle}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,0,0" Text="Runtime" Style="{StaticResource LabelMiniStyle}" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" Text=".NET 8 WPF, Windows desktop" Style="{StaticResource ValueMiniStyle}" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,0,0" Text="Capture" Style="{StaticResource LabelMiniStyle}" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" Text="Npcap runtime prerequisite, not vendored" Style="{StaticResource ValueMiniStyle}" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="12,0,0,0">
                <StackPanel>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel HorizontalAlignment="Center">
                            <Ellipse Width="150" Height="150" Margin="0,0,0,14">
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="/Views/Assets/Profile/ari-profile.jpg"
                                                Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                            </Ellipse>

                            <TextBlock Text="Ari Sulistiono"
                                       Foreground="{StaticResource TextMain}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="Substation Automation Engineer" TextWrapping="Wrap"
                                       Foreground="{StaticResource Accent}"
                                       FontSize="12" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>

                            <TextBlock Text="Industrial Communication &amp; Protocol Analyzer Developer"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="12" TextWrapping="Wrap"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Margin="0,4,0,12"/>

                            <Separator Margin="0,8,0,12" Background="{StaticResource BorderSoft}"/>

                            <TextBlock Style="{StaticResource BodyTextStyle}" FontSize="12" TextWrapping="Wrap" TextAlignment="Center">
Developed from practical field experience in substation automation, industrial communication, FAT/SAT workflow, and real troubleshooting scenarios.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Engineering Support" TextWrapping="Wrap" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Style="{StaticResource BodyTextStyle}" FontSize="12" TextWrapping="Wrap">
For project-specific validation, FAT/SAT workflow discussion, training, or maintenance planning, please contact:
                            </TextBlock>

                            <Border Margin="0,14,0,0"
                                    Background="#0B1220"
                                    BorderBrush="{StaticResource BorderSoft}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="14">
                                <TextBlock Text="admin@arisulistiono.com" FontSize="12"
                                           Foreground="{StaticResource TextMain}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="2" Background="#0B1A2A" BorderBrush="#294864" BorderThickness="1" CornerRadius="8" Margin="0,0,0,0">
            <Grid Margin="31,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto" MinWidth="276"/>
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center"
           Foreground="{StaticResource TextMuted}"
           FontSize="12.5"
           TextWrapping="Wrap"
           Text="Built for protection, automation, and commissioning engineers who need faster clues, cleaner visibility, and fewer trial-and-error loops." Height="34"/>


                <Button Grid.Column="1"
        Content="Close"
        Height="34"
        VerticalAlignment="Center"
        IsDefault="True"
        Click="Close_Click"
        Cursor="Hand"
        Foreground="White"
        Background="#0E6AC0"
        BorderBrush="#1C5F91"
        BorderThickness="1"
        FontWeight="SemiBold"
        RenderTransformOrigin="0.5,0.5" Margin="2,0,2,0">

                    <Button.RenderTransform>
                        <TranslateTransform/>
                    </Button.RenderTransform>

                    <Button.Effect>
                        <DropShadowEffect ShadowDepth="2"
                          BlurRadius="6"
                          Opacity="0.4"/>
                    </Button.Effect>

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="BtnBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                            </Border>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BtnBorder" Property="Background" Value="#1C5F91"/>
                                    <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#1C5F91"/>
                                </Trigger>

                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="BtnBorder" Property="Background" Value="#0E2032"/>
                                    <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#0E2032"/>
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <TranslateTransform Y="1"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Effect" Value="{x:Null}"/>
                                </Trigger>

                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="BtnBorder" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
