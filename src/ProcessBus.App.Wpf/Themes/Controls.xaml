<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- =========================================================
         VECTOR ICON SYSTEM v1 — Material/Fluent-like Path icons
         Use Path + Viewbox, not emoji/text font icons.
         ========================================================= -->
    <Geometry x:Key="IconAnalyzerGeometry">M3,17 L8,12 L12,15 L21,6 L21,9 L12,18 L8,15 L4.5,18.5 Z</Geometry>
    <Geometry x:Key="IconDiagnosticsGeometry">M3,12 H7 L9,5 L13,19 L16,12 H21 V14 H17.5 L13,22 L9,10 L8,14 H3 Z</Geometry>
    <Geometry x:Key="IconGooseGeometry">M4,5 H20 V17 H8 L4,21 V5 Z M7,8 H17 V10 H7 Z M7,12 H15 V14 H7 Z</Geometry>
    <Geometry x:Key="IconFramesGeometry">M5,4 H19 V8 H5 Z M5,10 H19 V14 H5 Z M5,16 H19 V20 H5 Z</Geometry>
    <Geometry x:Key="IconInfoGeometry">M11,10 H13 V18 H11 Z M11,6 H13 V8 H11 Z M12,2 A10,10 0 1 1 12,22 A10,10 0 1 1 12,2 Z M12,4 A8,8 0 1 0 12,20 A8,8 0 1 0 12,4 Z</Geometry>
    <Geometry x:Key="IconPlayGeometry">M8,5 L19,12 L8,19 Z</Geometry>
    <Geometry x:Key="IconStopGeometry">M7,7 H17 V17 H7 Z</Geometry>
    <Geometry x:Key="IconClearGeometry">M7,8 H17 V19 C17,20 16,21 15,21 H9 C8,21 7,20 7,19 Z M9,10 V19 H15 V10 Z M10,4 H14 L15,5 H20 V7 H4 V5 H9 Z</Geometry>
    <Geometry x:Key="IconNewGeometry">M11,5 H13 V11 H19 V13 H13 V19 H11 V13 H5 V11 H11 Z</Geometry>
    <Geometry x:Key="IconImportGeometry">M11,3 H13 V13 L17,9 L18.4,10.4 L12,16.8 L5.6,10.4 L7,9 L11,13 Z M5,19 H19 V21 H5 Z</Geometry>
    <Geometry x:Key="IconReportGeometry">M6,3 H15 L20,8 V21 H6 Z M14,4.5 V9 H18.5 M8,13 H18 M8,16 H18 M8,19 H14</Geometry>

    <Style x:Key="ToolbarVectorIconStyle" TargetType="Path">
        <Setter Property="Width" Value="14"/>
        <Setter Property="Height" Value="14"/>
        <Setter Property="Stretch" Value="Uniform"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Fill" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
    </Style>

    <Style x:Key="NavVectorIconStyle" TargetType="Path">
        <Setter Property="Width" Value="14"/>
        <Setter Property="Height" Value="14"/>
        <Setter Property="Stretch" Value="Uniform"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Fill" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
    </Style>

    <Style x:Key="ShellCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PremiumCardBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="10" />
    </Style>

    <Style x:Key="DenseGroupBorderStyle" TargetType="Border" BasedOn="{StaticResource ShellCardStyle}">
        <Setter Property="Padding" Value="8" />
    </Style>

    <Style x:Key="InnerSurfaceStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PanelSubtleBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="10" />
    </Style>

    <Style x:Key="PanelTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13.5" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="PanelSubtitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
    </Style>

    <Style x:Key="CompactLabelTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="CompactValueTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="MonoValueTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="MetricChipBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="8,3" />
        <Setter Property="Margin" Value="0,0,6,5" />
        <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
    </Style>

    <Style x:Key="SectionChipStyle" TargetType="Border">
        <Setter Property="Padding" Value="8,2" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Background" Value="#0D2740" />
        <Setter Property="BorderBrush" Value="#1C5F91" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Margin" Value="0,0,6,0" />
    </Style>

    <Style x:Key="HeaderButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="34" />
        <Setter Property="MinWidth" Value="82" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="Foreground" Value="#F5FBFF" />
        <Setter Property="Background" Value="#12263A" />
        <Setter Property="BorderBrush" Value="#294864" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            TextElement.Foreground="{TemplateBinding Foreground}"
                            RenderTransformOrigin="0.5,0.5"
                            SnapsToDevicePixels="True">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#3AA8FF"/>
                            <Setter TargetName="ButtonBorder" Property="Background" Value="#17314A"/>
                            <Setter TargetName="ButtonBorder" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1.025" ScaleY="1.025"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#6ED2FF"/>
                            <Setter TargetName="ButtonBorder" Property="Background" Value="#0B67BC"/>
                            <Setter TargetName="ButtonBorder" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.94" ScaleY="0.94"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.78"/>
                            <Setter Property="Foreground" Value="#BFD4EA"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PrimaryHeaderButtonStyle" TargetType="Button" BasedOn="{StaticResource HeaderButtonStyle}">
        <Setter Property="Background" Value="{StaticResource PremiumAccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderBrush" Value="#084A71" />
    </Style>

    <!-- =========================================================
 HEADER TOOLBAR DESIGN SYSTEM LOCK v1
 ========================================================= -->

    <Style x:Key="ToolbarButtonStyle"
       TargetType="Button"
       BasedOn="{StaticResource HeaderButtonStyle}">
        <Setter Property="Height" Value="34"/>
        <Setter Property="MinWidth" Value="82"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="Padding" Value="14,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="ToolbarPrimaryButtonStyle"
       TargetType="Button"
       BasedOn="{StaticResource ToolbarButtonStyle}">
        <Setter Property="Background" Value="#0E6AC0"/>
        <Setter Property="BorderBrush" Value="#6ED2FF"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <Style x:Key="ToolbarMutedButtonStyle"
       TargetType="Button"
       BasedOn="{StaticResource ToolbarButtonStyle}">
        <Setter Property="Background" Value="#12263A"/>
        <Setter Property="BorderBrush" Value="#294864"/>
        <Setter Property="Foreground" Value="#8FA8BF"/>
    </Style>

    <Style x:Key="ToolbarGhostButtonStyle"
       TargetType="Button"
       BasedOn="{StaticResource ToolbarButtonStyle}">
        <Setter Property="MinWidth" Value="76"/>
        <Setter Property="Background" Value="#0B1A2A"/>
        <Setter Property="BorderBrush" Value="#253D56"/>
        <Setter Property="Foreground" Value="#CFE7FF"/>
    </Style>


    <!-- =========================================================
     HYBRID TOOLBAR SYSTEM v2 — Material/Tailwind inspired
     Primary actions stay readable; utilities become satisfying icon controls.
     ========================================================= -->

    <Style x:Key="GlassToolTipStyle" TargetType="ToolTip">
        <Setter Property="Foreground" Value="#EAF6FF"/>
        <Setter Property="Background" Value="#101B2B"/>
        <Setter Property="BorderBrush" Value="#2A5B84"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="HasDropShadow" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="9"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HeroToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
        <Setter Property="Height" Value="38"/>
        <Setter Property="MinWidth" Value="96"/>
        <Setter Property="Padding" Value="16,0"/>
        <Setter Property="Background" Value="#0E7BE8"/>
        <Setter Property="BorderBrush" Value="#7BD8FF"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="DangerToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
        <Setter Property="Height" Value="38"/>
        <Setter Property="MinWidth" Value="92"/>
        <Setter Property="Padding" Value="16,0"/>
        <Setter Property="Background" Value="#201927"/>
        <Setter Property="BorderBrush" Value="#4E3046"/>
        <Setter Property="Foreground" Value="#F8A8BA"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="CircleToolbarButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="38"/>
        <Setter Property="Height" Value="38"/>
        <Setter Property="Margin" Value="7,0,0,0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Foreground" Value="#D8ECFF"/>
        <Setter Property="Background" Value="#0D1C2D"/>
        <Setter Property="BorderBrush" Value="#24445F"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="ToolTipService.InitialShowDelay" Value="180"/>
        <Setter Property="ToolTipService.ShowDuration" Value="5000"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            CornerRadius="19"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            RenderTransformOrigin="0.5,0.5"
                            SnapsToDevicePixels="True">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#123150"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="#49B8FF"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter TargetName="Root" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1.06" ScaleY="1.06"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#0B66B7"/>
                            <Setter TargetName="Root" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.94" ScaleY="0.94"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ProjectCircleButtonStyle" TargetType="Button" BasedOn="{StaticResource CircleToolbarButtonStyle}">
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Margin" Value="6,0,0,0"/>
        <Setter Property="Background" Value="#0A1726"/>
        <Setter Property="BorderBrush" Value="#20384F"/>
        <Setter Property="Foreground" Value="#CFE7FF"/>
    </Style>

    <Style x:Key="HeaderCircleButtonStyle" TargetType="Button" BasedOn="{StaticResource CircleToolbarButtonStyle}">
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="Background" Value="#0D1C2D"/>
        <Setter Property="BorderBrush" Value="#2A4762"/>
        <Setter Property="Foreground" Value="#D8ECFF"/>
    </Style>

    <!-- =========================================================
     UNIFIED INPUT SYSTEM v1
     TextBox + ComboBox + Toggle/Button visual language
     ========================================================= -->

    <Style x:Key="UnifiedInputBaseStyle" TargetType="Control">
        <Setter Property="Height" Value="30"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Background" Value="#0B1A2A"/>
        <Setter Property="BorderBrush" Value="#1C3854"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style x:Key="UnifiedTextBoxStyle"
       TargetType="TextBox"
       BasedOn="{StaticResource UnifiedInputBaseStyle}">
        <Setter Property="Padding" Value="10,2"/>
        <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource AccentSoftBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Box"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="7"
                        SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                  Margin="{TemplateBinding Padding}"
                                  VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentStrongBrush}"/>
                            <Setter TargetName="Box" Property="Background" Value="#102236"/>
                        </Trigger>

                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="#6ED2FF"/>
                            <Setter TargetName="Box" Property="Background" Value="#0E2A44"/>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="UnifiedToggleButtonStyle"
       TargetType="Button"
       BasedOn="{StaticResource HeaderButtonStyle}">
        <Setter Property="Height" Value="30"/>
        <Setter Property="MinWidth" Value="86"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="Background" Value="#0B1A2A"/>
        <Setter Property="BorderBrush" Value="#1C3854"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <Style x:Key="ModeToggleButtonStyle"
       TargetType="Button"
       BasedOn="{StaticResource UnifiedToggleButtonStyle}">
        <Setter Property="Foreground" Value="#CFE7FF"/>
    </Style>

    <Style x:Key="ModeToggleButtonActiveStyle"
       TargetType="Button"
       BasedOn="{StaticResource HeaderButtonStyle}">
        <Setter Property="Height" Value="30"/>
        <Setter Property="MinWidth" Value="86"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="Background" Value="#0E6AC0"/>
        <Setter Property="BorderBrush" Value="#6ED2FF"/>
    </Style>

    <Style x:Key="CompactSearchBoxStyle"
       TargetType="TextBox"
       BasedOn="{StaticResource UnifiedTextBoxStyle}">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontWeight" Value="Normal"/>
    </Style>

    <Style x:Key="AnalyzerTabControlStyle" TargetType="TabControl">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <ContentPresenter ContentSource="SelectedContent"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="WorkspaceSegmentHostStyle" TargetType="Border">
        <Setter Property="Padding" Value="5"/>
        <Setter Property="CornerRadius" Value="23"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#203247"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#121A29" Offset="0"/>
                    <GradientStop Color="#0B1320" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#000000" BlurRadius="18" ShadowDepth="3" Opacity="0.35"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AnalyzerTabButtonStyle" TargetType="RadioButton">
        <Setter Property="Foreground" Value="#B8C8D9"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Width" Value="136"/>
        <Setter Property="Height" Value="38"/>
        <Setter Property="Margin" Value="2,0"/>
        <Setter Property="Padding" Value="14,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid x:Name="Root"
                          Width="{TemplateBinding Width}"
                          Height="{TemplateBinding Height}"
                          RenderTransformOrigin="0.5,0.5"
                          SnapsToDevicePixels="True">
                        <Grid.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Grid.RenderTransform>

                        <!-- Selected moving-feel blue pill surface. It fades/scales in on Checked. -->
                        <Border x:Name="SelectedPill"
                                CornerRadius="20"
                                Opacity="0"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="0.88" ScaleY="0.86"/>
                            </Border.RenderTransform>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1189FF" Offset="0"/>
                                    <GradientStop Color="#0A5FB8" Offset="0.55"/>
                                    <GradientStop Color="#073A7A" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#1B8CFF" BlurRadius="16" ShadowDepth="0" Opacity="0.42"/>
                            </Border.Effect>
                        </Border>

                        <!-- Soft hover glass layer. -->
                        <Border x:Name="HoverPill"
                                CornerRadius="20"
                                Background="#172638"
                                Opacity="0"/>

                        <ContentPresenter x:Name="ContentHost"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HoverPill" Property="Opacity" Value="0.72"/>
                            <Setter Property="Foreground" Value="#F2FAFF"/>
                            <Setter TargetName="Root" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1.018" ScaleY="1.018"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>

                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="SelectedPill" Property="Opacity" Value="0"/>
                            <Setter TargetName="HoverPill" Property="Opacity" Value="0"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.975" ScaleY="0.975"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style.Triggers>
            <EventTrigger RoutedEvent="RadioButton.Checked">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         From="0.82" To="1"
                                         Duration="0:0:0.16"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SourceListItemStyle" TargetType="ListViewItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Margin" Value="0,0,0,4" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Border x:Name="ItemBorder"
                            BorderBrush="#1F405F"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="8,7">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0C1F32" Offset="0"/>
                                <GradientStop Color="#081827" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1.015" ScaleY="1.015"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="#0E2A44" />
                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource AccentStrongBrush}" />
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#5FAFE8" />
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1.015" ScaleY="1.015"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GridListViewStyle" TargetType="ListView">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
        <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
    </Style>

    <Style x:Key="EventListItemStyle" TargetType="ListViewItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,0,2" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Border x:Name="ItemBorder"
                            Background="Transparent"
                            CornerRadius="6"
                            Padding="6,4">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="#102236"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="#12314A"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DenseExpanderStyle" TargetType="Expander">
        <Setter Property="Margin" Value="0,4,0,0" />
        <Setter Property="Foreground" Value="#F5FBFF" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Background" Value="#0B1A2A"/>
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="MinHeight" Value="28"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd"
                        Background="{TemplateBinding Background}"
                        Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#123754"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#0E4E86"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CompactComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Height" Value="30"/>
        <Setter Property="MinWidth" Value="92"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Background" Value="#0B1A2A"/>
        <Setter Property="BorderBrush" Value="#1C3854"/>
        <Setter Property="Padding" Value="10,2"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItemStyle}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton"
                                  Focusable="False"
                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                  ClickMode="Press"
                                  Background="{TemplateBinding Background}"
                                  BorderBrush="{TemplateBinding BorderBrush}"
                                  BorderThickness="{TemplateBinding BorderThickness}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="Box"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="7"
                                        SnapsToDevicePixels="True">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="28"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- TEXT (FIXED ALIGNMENT) -->
                                            <TextBlock Grid.Column="0"
                                               Text="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Margin="10,0,4,0"
                                               TextTrimming="CharacterEllipsis"/>

                                            <!-- ARROW -->
                                            <Path Grid.Column="1"
                                          Width="9"
                                          Height="5"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Fill="{StaticResource TextSecondaryBrush}"
                                          Data="M 0 0 L 9 0 L 4.5 5 Z"/>
                                        </Grid>
                                    </Border>

                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentStrongBrush}"/>
                                            <Setter TargetName="Box" Property="Background" Value="#102236"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Box" Property="BorderBrush" Value="#6ED2FF"/>
                                            <Setter TargetName="Box" Property="Background" Value="#0E2A44"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <Popup x:Name="PART_Popup"
                           AllowsTransparency="True"
                           Focusable="False"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           Placement="Bottom"
                           PopupAnimation="Fade">
                            <Border Background="#0B1A2A"
                                BorderBrush="{StaticResource AccentStrongBrush}"
                                BorderThickness="1"
                                CornerRadius="7"
                                MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <ScrollViewer Margin="0"
                                          Padding="0"
                                          Background="Transparent">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Header toolbar ComboBox must be declared after CompactComboBoxStyle -->
    <Style x:Key="ToolbarAdapterComboBoxStyle"
       TargetType="ComboBox"
       BasedOn="{StaticResource CompactComboBoxStyle}">
        <Setter Property="Height" Value="34"/>
        <Setter Property="Width" Value="280"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    
    <Style x:Key="ModernScrollViewerStyle" TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="PanningMode" Value="VerticalOnly"/>
    </Style>
    <Style x:Key="DenseMetricCardStyle" TargetType="Border">
        <Setter Property="Padding" Value="10"/>
        <Setter Property="Background" Value="#0B1A2A"/>
        <Setter Property="BorderBrush" Value="#1B344F"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
    </Style>
    <Style x:Key="WorkspaceToolbar" TargetType="Grid">
        <Setter Property="Height" Value="64"/>
        <Setter Property="Margin" Value="16,8,16,0"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style x:Key="ToolbarStack" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <SolidColorBrush x:Key="CardBg" Color="#1A2333"/>

    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBg}"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Margin" Value="0"/>
    </Style>

    <Style x:Key="CardHeader" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <Style x:Key="SelectableCard" TargetType="Border">
        <Setter Property="Background" Value="#142033"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

</ResourceDictionary>
