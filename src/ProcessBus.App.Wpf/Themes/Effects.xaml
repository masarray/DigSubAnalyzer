<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DropShadowEffect x:Key="CardShadow"
                      BlurRadius="20"
                      ShadowDepth="4"
                      Opacity="0.35"
                      Color="#000000"/>

    <DropShadowEffect x:Key="SoftGlow"
                      BlurRadius="16"
                      ShadowDepth="0"
                      Opacity="0.42"
                      Color="#1D8FFF"/>

    <LinearGradientBrush x:Key="PremiumHeaderBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0E2134" Offset="0"/>
        <GradientStop Color="#081421" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="PremiumAccentBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0C6FD6" Offset="0"/>
        <GradientStop Color="#20A8FF" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="PremiumCardBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0E2032" Offset="0"/>
        <GradientStop Color="#091827" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>