                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="18"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <DockPanel Grid.Column="0">
                                            <StackPanel DockPanel.Dock="Bottom"
                                                        Margin="0,10,0,0">
                                                <Button Command="{Binding CopyEvidenceCommand}"
                                                        Height="28"
                                                        Width="132"
                                                        HorizontalAlignment="Left"
                                                        Style="{StaticResource ToolbarGhostButtonStyle}">
                                                    <TextBlock Text="Copy Snapshot"
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                                </Button>
                                                <TextBlock Text="{Binding EvidenceCopyStatusText}"
                                                           Foreground="#8FAAC3"
                                                           FontSize="10.5"
                                                           TextWrapping="Wrap"
                                                           Margin="0,4,0,0"/>
                                            </StackPanel>

                                            <StackPanel>
                                                <TextBlock Text="ENGINEERING SNAPSHOT"
                                                           Foreground="#8FAAC3"
                                                           FontSize="10.5"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding EvidenceVerdictText}"
                                                           Foreground="#FFFFFF"
                                                           FontSize="17"
                                                           FontWeight="Bold"
                                                           TextWrapping="Wrap"
                                                           Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </DockPanel>

                                        <Border Grid.Column="1"
                                                Width="1"
                                                Background="#244564"
                                                Margin="0,0,16,0"/>

                                        <UniformGrid Grid.Column="2" Columns="2">
                                            <StackPanel Margin="0,0,14,0">
                                                <TextBlock Text="{Binding EvidenceStandardText}"
                                                           Foreground="#D6E8F8"
                                                           FontSize="11.5"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding EvidenceIntegrityText}"
                                                           Foreground="#D6E8F8"
                                                           FontSize="11.5"
                                                           TextWrapping="Wrap"
                                                           Margin="0,5,0,0"/>
                                                <TextBlock Text="{Binding EvidenceTimingText}"
                                                           Foreground="#D6E8F8"
                                                           FontSize="11.5"
                                                           TextWrapping="Wrap"
                                                           Margin="0,5,0,0"/>
                                                <TextBlock Text="{Binding EvidencePtpText}"
                                                           Foreground="#D6E8F8"
                                                           FontSize="11.5"
                                                           TextWrapping="Wrap"
                                                           Margin="0,5,0,0"/>
                                                <TextBlock Text="{Binding TimingConfidenceText}"
                                                           Foreground="#8FAAC3"
                                                           FontSize="11.5"
                                                           TextWrapping="Wrap"
                                                           Margin="0,5,0,0"/>
                                            </StackPanel>

                                            <StackPanel>
                                                <TextBlock Text="{Binding EvidenceDecodeText}"
                                                           Foreground="#D6E8F8"
                                                           FontSize="11.5"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding EvidenceCapturePathText}"
                                                           Foreground="#8FAAC3"
                                                           FontSize="11.5"
                                                           TextWrapping="Wrap"
                                                           Margin="0,5,0,0"/>
                                            </StackPanel>
                                        </UniformGrid>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="5"
                                        Style="{StaticResource DenseGroupBorderStyle}"
                                        Padding="12,10"
                                        Margin="0,14,0,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="TIMING REFERENCE" Foreground="#8FAAC3" FontSize="10.5" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding PtpStatusText}" Foreground="#FFFFFF" FontSize="15" FontWeight="Bold" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="14,0,10,0">
                                            <TextBlock Text="{Binding PtpDomainText}" Foreground="#D6E8F8" FontSize="11.5"/>
                                            <TextBlock Text="{Binding PtpGrandmasterText}" Foreground="#D6E8F8" FontSize="11.5" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                            <TextBlock Text="{Binding PtpClockQualityText}" Foreground="#8FAAC3" FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="{Binding PtpRateText}" Foreground="#D6E8F8" FontSize="11.5" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding PtpProfileText}" Foreground="#8FAAC3" FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                            <TextBlock Text="{Binding TimingMetricText}" Foreground="#8FAAC3" FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Event Log: useful, readable, not object-name -->
                                <Border Grid.Row="6"
                                    VerticalAlignment="Stretch"
                                    Margin="0,0,0,0"
                                    Style="{StaticResource DenseGroupBorderStyle}">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Top"
                                               Text="{Binding DiagnosticFindingsHeaderText}"
                                               Style="{StaticResource PanelTitleTextStyle}"
                                               Margin="0,0,0,8"/>

                                        <ListView ItemsSource="{Binding Events}"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Foreground="#EAF6FF"
                                              ItemContainerStyle="{StaticResource EventListItemStyle}"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              VerticalAlignment="Stretch">
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="108"/>
                                                            <ColumnDefinition Width="74"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0"
                                                               Text="{Binding TimestampUtc, StringFormat={}{0:HH:mm:ss.fff}}"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               FontFamily="Consolas"
                                                               FontSize="11"
                                                               VerticalAlignment="Center"/>

                                                        <Border Grid.Column="1"
                                                            Margin="0,0,10,0"
                                                            Padding="6,1"
                                                            Background="{StaticResource PanelAltBrush}"
                                                            CornerRadius="5"
                                                            HorizontalAlignment="Left">
                                                            <TextBlock Text="{Binding Severity}"
                                                                   Foreground="{StaticResource AccentBrush}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="10.5"/>
                                                        </Border>

                                                        <TextBlock Grid.Column="2"
                                                               Text="{Binding Message}"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               FontSize="11.5"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </DockPanel>
                                </Border>
                            </Grid>
                        </TabItem>

                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0" Foreground="#EAF6FF" Text="&#xE8AB;"/>
                                    <TextBlock Text="GOOSE" Foreground="#EAF6FF" FontWeight="SemiBold"/>
                                </StackPanel>
                            </TabItem.Header>

                            <Grid Margin="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="400"/>
                                </Grid.ColumnDefinitions>

                                <!-- Main event timeline: lean, readable, no debug ornaments. -->
                                <Border Grid.Column="0"
                                        Style="{StaticResource DenseGroupBorderStyle}"
                                        Padding="14">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="12"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="GOOSE Event Timeline"
                                                           Foreground="#F4FAFF"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                                <Border Margin="10,0,0,0"
                                                        Padding="8,3"
                                                        Background="#0B2A45"
                                                        BorderBrush="#1B5C8A"
                                                        BorderThickness="1"
                                                        CornerRadius="10">
                                                    <TextBlock Text="{Binding GooseTotalMessagesText}"
                                                               Foreground="#7BD8FF"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border Padding="8,3"
                                                        Background="#0A1928"
                                                        BorderBrush="#1D3C59"
                                                        BorderThickness="1"
                                                        CornerRadius="9"
                                                        Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding GooseFilterSummaryText}"
                                                               Foreground="#AFC4DA"
                                                               FontSize="10.5"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>

                                        <DataGrid Grid.Row="2"
                                                  Style="{StaticResource DarkDataGridStyle}"
                                                  ItemsSource="{Binding GooseHistoryView}"
                                                  SelectedItem="{Binding SelectedGooseTrafficRow, Mode=TwoWay}"
                                                  AutoGenerateColumns="False"
                                                  IsReadOnly="True"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  HeadersVisibility="Column"
                                                  SelectionMode="Single"
                                                  SelectionUnit="FullRow"
                                                  FocusVisualStyle="{x:Null}"
                                                  FontFamily="Segoe UI Variable Text, Segoe UI"
                                                  FontSize="12.5"
                                                  RowHeight="42"
                                                  EnableRowVirtualization="True"
                                                  EnableColumnVirtualization="True"
                                                  VirtualizingPanel.IsVirtualizing="True"
                                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                                  ScrollViewer.CanContentScroll="True"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                  MouseEnter="GooseTraffic_Interaction"
                                                  MouseMove="GooseTraffic_Interaction"
                                                  PreviewMouseDown="GooseTraffic_ClickInteraction">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Time" Binding="{Binding TimeText}" Width="112">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                                            <Setter Property="Foreground" Value="#DDEEFF"/>
                                                            <Setter Property="FontSize" Value="12"/>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>

                                                <DataGridTextColumn Header="Δt" Binding="{Binding DeltaText}" Width="78">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                                            <Setter Property="Foreground" Value="#91AAC2"/>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>

                                                <DataGridTemplateColumn Header="Event" Width="118">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Border Padding="8,3"
                                                                    Background="#13202D"
                                                                    BorderBrush="#273A4E"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8"
                                                                    HorizontalAlignment="Left"
                                                                    VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding EventType}"
                                                                           Foreground="{Binding EventBrush}"
                                                                           FontWeight="SemiBold"
                                                                           FontSize="11"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>

                                                <DataGridTemplateColumn Header="Publisher / GOOSE ID" Width="285">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding GoId}"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="#F4FAFF"
                                                                       FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       ToolTip="{Binding GoCbRef}"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>

                                                <DataGridTemplateColumn Header="stNum / sqNum" Width="106">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#DDEEFF">
                                                                <TextBlock.Text>
                                                                    <MultiBinding StringFormat="{}{0} / {1}">
                                                                        <Binding Path="StNum"/>
                                                                        <Binding Path="SqNum"/>
                                                                    </MultiBinding>
                                                                </TextBlock.Text>
                                                            </TextBlock>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>

                                                <DataGridTemplateColumn Header="Changed values" Width="*">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding DisplayValuesText}"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="#D9ECFF"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>

                                <!-- Right inspector: clean grouped information, typed values emphasized. -->
                                <Border Grid.Column="2"
                                        Style="{StaticResource DenseGroupBorderStyle}"
                                        Padding="14">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel>
                                            <TextBlock Text="GOOSE Inspector"
                                                       Foreground="#F4FAFF"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="Selected publisher and typed DataSet values"
                                                       Foreground="#7FA8CC"
                                                       FontSize="11"
                                                       Margin="0,3,0,14"/>

                                            <Border Padding="13"
                                                    Background="#081827"
                                                    BorderBrush="#1B344F"
                                                    BorderThickness="1"
                                                    CornerRadius="12"
                                                    Margin="0,0,0,12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="112"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="GOOSE ID" Foreground="#7FA8CC" FontSize="11" Margin="0,3,10,3"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedGooseTrafficRow.GoId}" Foreground="#F4FAFF" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="0,3,0,3"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Publisher" Foreground="#7FA8CC" FontSize="11" Margin="0,3,10,3"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedGooseTrafficRow.GoCbRef}" Foreground="#DDEEFF" TextWrapping="Wrap" Margin="0,3,0,3"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="APPID" Foreground="#7FA8CC" FontSize="11" Margin="0,3,10,3"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedGooseTrafficRow.AppId}" Foreground="#DDEEFF" Margin="0,3,0,3"/>
                                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="stNum / sqNum" Foreground="#7FA8CC" FontSize="11" Margin="0,3,10,3"/>
                                                    <TextBlock Grid.Row="3" Grid.Column="1" Foreground="#DDEEFF" FontWeight="SemiBold" Margin="0,3,0,3">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}{0} / {1}">
                                                                <Binding Path="SelectedGooseTrafficRow.StNum"/>
                                                                <Binding Path="SelectedGooseTrafficRow.SqNum"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>

                                            <Border Padding="13"
                                                    Background="#081827"
                                                    BorderBrush="#1B344F"
                                                    BorderThickness="1"
                                                    CornerRadius="12"
                                                    Margin="0,0,0,12">
                                                <StackPanel>
                                                    <TextBlock Text="Communication / Network"
                                                               Foreground="#F4FAFF"
                                                               FontSize="13.5"
                                                               FontWeight="SemiBold"
                                                               Margin="0,0,0,9"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="112"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Src MAC" Foreground="#7FA8CC" FontSize="11" Margin="0,3,10,3"/>
                                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedGooseTrafficRow.SourceMac}" Foreground="#DDEEFF" Margin="0,3,0,3"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Dst MAC" Foreground="#7FA8CC" FontSize="11" Margin="0,3,10,3"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedGooseTrafficRow.DestinationMac}" Foreground="#DDEEFF" Margin="0,3,0,3"/>
                                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="VLAN" Foreground="#7FA8CC" FontSize="11" Margin="0,3,10,3"/>
                                                        <TextBlock Grid.Row="2" Grid.Column="1" Foreground="#DDEEFF" Margin="0,3,0,3">
                                                            <TextBlock.Text>
                                                                <MultiBinding StringFormat="{}ID {0} · Priority {1}">
                                                                    <Binding Path="SelectedGooseTrafficRow.VlanId"/>
                                                                    <Binding Path="SelectedGooseTrafficRow.VlanPriority"/>
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="DataSet" Foreground="#7FA8CC" FontSize="11" Margin="0,3,10,3"/>
                                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedGooseTrafficRow.DataSet}" Foreground="#DDEEFF" TextWrapping="Wrap" Margin="0,3,0,3"/>
                                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="ConfRev" Foreground="#7FA8CC" FontSize="11" Margin="0,3,10,3"/>
                                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedGooseMessage.ConfRev}" Foreground="#DDEEFF" Margin="0,3,0,3"/>
                                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="TTL" Foreground="#7FA8CC" FontSize="11" Margin="0,3,10,3"/>
                                                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedGooseMessage.TimeAllowedToLiveMilliseconds, StringFormat={}{0} ms}" Foreground="#DDEEFF" Margin="0,3,0,3"/>
                                                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Flags" Foreground="#7FA8CC" FontSize="11" Margin="0,3,10,3"/>
                                                        <TextBlock Grid.Row="6" Grid.Column="1" Foreground="#DDEEFF" Margin="0,3,0,3">
                                                            <TextBlock.Text>
                                                                <MultiBinding StringFormat="{}Test {0} · NdsCom {1}">
                                                                    <Binding Path="SelectedGooseTrafficRow.TestText"/>
                                                                    <Binding Path="SelectedGooseTrafficRow.NeedsCommissionText"/>
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <Border Padding="13"
                                                    Background="#081827"
                                                    BorderBrush="#1B344F"
                                                    BorderThickness="1"
                                                    CornerRadius="12">
                                                <StackPanel>
                                                    <DockPanel Margin="0,0,0,10">
                                                        <TextBlock DockPanel.Dock="Left"
                                                                   Text="DataSet Values"
                                                                   Foreground="#F4FAFF"
                                                                   FontSize="13.5"
                                                                   FontWeight="SemiBold"/>
                                                        <TextBlock DockPanel.Dock="Right"
                                                                   Text="{Binding SelectedGooseTrafficRow.DatasetEntryCountText, StringFormat=({0})}"
                                                                   Foreground="#FFBE52"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"/>
                                                    </DockPanel>
                                                    <TextBlock Text="{Binding SelectedGooseSemanticText}"
                                                               Foreground="#8FAAC3"
                                                               FontSize="11"
                                                               TextWrapping="Wrap"
                                                               Margin="0,0,0,10"/>

                                                    <DataGrid Style="{StaticResource DarkDataGridStyle}"
                                                              ItemsSource="{Binding SelectedGooseDatasetValues}"
                                                              AutoGenerateColumns="False"
                                                              IsReadOnly="True"
                                                              HeadersVisibility="Column"
                                                              CanUserAddRows="False"
                                                              CanUserDeleteRows="False"
                                                              SelectionMode="Single"
                                                              SelectionUnit="FullRow"
                                                              FocusVisualStyle="{x:Null}"
                                                              FontFamily="Segoe UI Variable Text, Segoe UI"
                                                              FontSize="11.5"
                                                              RowHeight="54"
                                                              MinHeight="180"
                                                              MaxHeight="360"
                                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn Header="Name" Binding="{Binding NameText}" Width="*">
                                                                <DataGridTextColumn.ElementStyle>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                                        <Setter Property="Foreground" Value="#E6F4FF"/>
                                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                                    </Style>
                                                                </DataGridTextColumn.ElementStyle>
                                                            </DataGridTextColumn>
                                                            <DataGridTextColumn Header="Type" Binding="{Binding TypeText}" Width="132">
                                                                <DataGridTextColumn.ElementStyle>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                                        <Setter Property="Foreground" Value="#8FAAC3"/>
                                                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                                                        <Setter Property="ToolTip" Value="{Binding SemanticText}"/>
                                                                    </Style>
                                                                </DataGridTextColumn.ElementStyle>
                                                            </DataGridTextColumn>
                                                            <DataGridTemplateColumn Header="Value" Width="150">
                                                                <DataGridTemplateColumn.CellTemplate>
                                                                    <DataTemplate>
                                                                        <StackPanel VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding DisplayValueText}"
                                                                                       FontWeight="SemiBold"
                                                                                       Foreground="{Binding ValueBrush}"
                                                                                       TextTrimming="CharacterEllipsis"/>
                                                                            <TextBlock Margin="0,3,0,0"
                                                                                       Text="{Binding ChangeText}"
                                                                                       Visibility="{Binding ChangeVisibility}"
                                                                                       Foreground="#FFBE52"
                                                                                       FontSize="10.5"
                                                                                       TextTrimming="CharacterEllipsis"/>
                                                                        </StackPanel>
                                                                    </DataTemplate>
                                                                </DataGridTemplateColumn.CellTemplate>
                                                            </DataGridTemplateColumn>
                                                        </DataGrid.Columns>
                                                    </DataGrid>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>
                            </Grid>                        </TabItem>

                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0" Foreground="#EAF6FF" Text="&#xE916;"/>
                                    <TextBlock Text="Timing / PTP" Foreground="#EAF6FF" FontWeight="SemiBold"/>
                                </StackPanel>
                            </TabItem.Header>

                            <Grid Margin="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="14"/>
                                    <RowDefinition Height="1.05*"/>
                                    <RowDefinition Height="14"/>
                                    <RowDefinition Height="0.95*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Style="{StaticResource DenseGroupBorderStyle}" Padding="16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.15*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="1.1*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="1.2*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Style="{StaticResource DenseMetricCardStyle}" Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="PTP Reference" Foreground="#8FB8D8" FontSize="11" FontWeight="SemiBold"/>
                                                <TextBlock Margin="0,6,0,0" Text="{Binding PtpStatusText}" Foreground="#F4FAFF" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                <TextBlock Margin="0,6,0,0" Text="{Binding PtpTransportText}" Foreground="#8FAAC3" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2" Style="{StaticResource DenseMetricCardStyle}" Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="Grandmaster" Foreground="#8FB8D8" FontSize="11" FontWeight="SemiBold"/>
                                                <TextBlock Margin="0,6,0,0" Text="{Binding PtpGrandmasterText}" Foreground="#F4FAFF" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                <TextBlock Margin="0,6,0,0" Text="{Binding PtpDomainText}" Foreground="#8FAAC3"/>
                                                <TextBlock Margin="0,3,0,0" Text="{Binding PtpClockQualityText}" Foreground="#8FAAC3" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="4" Style="{StaticResource DenseMetricCardStyle}" Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="Message Rates" Foreground="#8FB8D8" FontSize="11" FontWeight="SemiBold"/>
                                                <TextBlock Margin="0,6,0,0" Text="{Binding PtpRateText}" Foreground="#F4FAFF" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                <TextBlock Margin="0,6,0,0" Text="{Binding PtpProfileText}" Foreground="#8FAAC3" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.1*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="1.4*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Style="{StaticResource DenseGroupBorderStyle}" Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="Timing Confidence" Style="{StaticResource PanelTitleTextStyle}"/>
                                            <TextBlock Margin="0,4,0,14" Text="How much trust the analyzer can place on packet-arrival timing." Style="{StaticResource PanelSubtitleTextStyle}" TextWrapping="Wrap"/>

                                            <Border Style="{StaticResource DenseMetricCardStyle}" Padding="14" Margin="0,0,0,10">
                                                <StackPanel>
                                                    <TextBlock Text="Current confidence" Foreground="#8FB8D8" FontSize="11" FontWeight="SemiBold"/>
                                                    <TextBlock Margin="0,7,0,0" Text="{Binding TimingConfidenceText}" Foreground="#F6D781" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Style="{StaticResource DenseMetricCardStyle}" Padding="14">
                                                <StackPanel>
                                                    <TextBlock Text="Timestamp source" Foreground="#8FB8D8" FontSize="11" FontWeight="SemiBold"/>
                                                    <TextBlock Margin="0,7,0,0" Text="{Binding TimestampSourceText}" Foreground="#EAF6FF" TextWrapping="Wrap"/>
                                                    <TextBlock Margin="0,7,0,0" Text="{Binding AdapterTimingRiskText}" Foreground="#8FAAC3" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" Style="{StaticResource DenseGroupBorderStyle}" Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="SV Timing Correlation" Style="{StaticResource PanelTitleTextStyle}"/>
                                            <TextBlock Margin="0,4,0,14" Text="Combines SV sequence continuity, arrival variation, adapter quality, and observed PTP traffic." Style="{StaticResource PanelSubtitleTextStyle}" TextWrapping="Wrap"/>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0" Style="{StaticResource DenseMetricCardStyle}" Padding="14">
                                                    <StackPanel>
                                                        <TextBlock Text="Arrival Variation" Foreground="#8FB8D8" FontSize="11" FontWeight="SemiBold"/>
                                                        <TextBlock Margin="0,7,0,0" Text="{Binding JitterText}" Foreground="#F4FAFF" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                        <TextBlock Margin="0,5,0,0" Text="{Binding LatencyText}" Foreground="#8FAAC3"/>
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Column="2" Style="{StaticResource DenseMetricCardStyle}" Padding="14">
                                                    <StackPanel>
                                                        <TextBlock Text="Sequence / Loss" Foreground="#8FB8D8" FontSize="11" FontWeight="SemiBold"/>
                                                        <TextBlock Margin="0,7,0,0" Text="{Binding SequenceStatusText}" Foreground="#F4FAFF" FontSize="16" FontWeight="SemiBold"/>
                                                        <TextBlock Margin="0,5,0,0" Text="{Binding PacketLossText}" Foreground="#8FAAC3"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <Border Margin="0,14,0,0" Style="{StaticResource DenseMetricCardStyle}" Padding="14">
                                                <StackPanel>
                                                    <TextBlock Text="Interpretation" Foreground="#8FB8D8" FontSize="11" FontWeight="SemiBold"/>
                                                    <TextBlock Margin="0,7,0,0" Text="{Binding TimingReferenceText}" Foreground="#EAF6FF" TextWrapping="Wrap"/>
                                                    <TextBlock Margin="0,7,0,0" Text="{Binding TimingMetricText}" Foreground="#8FAAC3" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Border Grid.Row="4" Style="{StaticResource DenseGroupBorderStyle}" Padding="16">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="10"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <DockPanel>
                                            <TextBlock Text="PTP Event Timeline" Style="{StaticResource PanelTitleTextStyle}" DockPanel.Dock="Left"/>
                                            <TextBlock Text="Raw PTP messages captured by this analyzer; Wireshark is not required for basic verification."
                                                       Foreground="#8FAAC3"
                                                       FontSize="11"
                                                       HorizontalAlignment="Right"/>
                                        </DockPanel>

                                        <DataGrid Grid.Row="2"
                                                  Style="{StaticResource DarkDataGridStyle}"
                                                  ItemsSource="{Binding PtpEvents}"
                                                  AutoGenerateColumns="False"
                                                  IsReadOnly="True"
                                                  HeadersVisibility="Column"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  CanUserReorderColumns="False"
                                                  CanUserResizeRows="False"
                                                  CanUserSortColumns="False"
                                                  GridLinesVisibility="None"
                                                  RowHeight="30"
                                                  FontFamily="Segoe UI Variable Text, Segoe UI"
                                                  FontSize="11.5"
                                                  EnableRowVirtualization="True"
                                                  EnableColumnVirtualization="True"
                                                  VirtualizingPanel.IsVirtualizing="True"
                                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Time" Binding="{Binding TimeText}" Width="110"/>
                                                <DataGridTextColumn Header="Transport" Binding="{Binding Transport}" Width="110"/>
                                                <DataGridTextColumn Header="Message" Binding="{Binding MessageType}" Width="120"/>
                                                <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="170"/>
                                                <DataGridTextColumn Header="Destination" Binding="{Binding Destination}" Width="170"/>
                                                <DataGridTextColumn Header="Domain" Binding="{Binding DomainText}" Width="70"/>
                                                <DataGridTextColumn Header="Seq" Binding="{Binding SequenceIdText}" Width="70"/>
                                                <DataGridTextColumn Header="Clock ID" Binding="{Binding ClockIdentity}" Width="*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </TabItem>


                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0" Foreground="#EAF6FF" Text="&#xE8D4;"/>
                                    <TextBlock Text="SCL" Foreground="#EAF6FF" FontWeight="SemiBold"/>
                                </StackPanel>
                            </TabItem.Header>

                            <Grid Margin="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Style="{StaticResource DenseGroupBorderStyle}" Padding="14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="SCL Engineering Context" Style="{StaticResource PanelTitleTextStyle}"/>
                                            <TextBlock Margin="0,4,0,0"
                                                       Text="Import SCD / CID / ICD / IID files, inspect IED cards, and build semantic mapping for SV and GOOSE streams."
                                                       Style="{StaticResource PanelSubtitleTextStyle}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Command="{Binding LoadSclCommand}" Style="{StaticResource HeroToolbarButtonStyle}" MinWidth="104" Height="34" Padding="14,0">
                                                <TextBlock Text="Import SCL" FontWeight="SemiBold"/>
                                            </Button>
                                            <Button Command="{Binding ClearSclCommand}" Style="{StaticResource ToolbarMutedButtonStyle}" MinWidth="70" Height="34" Padding="12,0" Margin="8,0,0,0">
                                                <TextBlock Text="Clear" FontWeight="SemiBold"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.18*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="0.92*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Semantic stream catalog: filtered by the left SCL Explorer selection -->
                                    <Border Grid.Column="0" Style="{StaticResource DenseGroupBorderStyle}" Padding="14">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="10"/>
                                                <RowDefinition Height="0.82*"/>
                                                <RowDefinition Height="12"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="10"/>
                                                <RowDefinition Height="1.18*"/>
                                            </Grid.RowDefinitions>
                                            <DockPanel>
                                                <StackPanel DockPanel.Dock="Left">
                                                    <TextBlock Text="SV / GOOSE Semantic Stream Catalog" Style="{StaticResource PanelTitleTextStyle}"/>
                                                    <TextBlock Margin="0,4,0,0"
                                                               Text="Filtered by selected IED in the SCL Explorer."
                                                               Foreground="#8FAAC3"
                                                               FontSize="11"/>
                                                </StackPanel>
                                                <Border HorizontalAlignment="Right"
                                                        VerticalAlignment="Top"
                                                        Background="#071A2B"
                                                        BorderBrush="#1F4E76"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Padding="10,5">
                                                    <TextBlock Text="{Binding SclWorkspaceStatusText}" Foreground="#8FCBFF" FontSize="11" FontWeight="SemiBold"/>
                                                </Border>
                                            </DockPanel>

                                            <DataGrid Grid.Row="2"
                                                      Style="{StaticResource DarkDataGridStyle}"
                                                      ItemsSource="{Binding SclFilteredStreamCatalog}"
                                                      SelectedItem="{Binding SelectedSclStreamCatalog, Mode=TwoWay}"
                                                      AutoGenerateColumns="False"
                                                      IsReadOnly="True"
                                                      HeadersVisibility="Column"
                                                      CanUserAddRows="False"
                                                      CanUserDeleteRows="False"
                                                      CanUserSortColumns="False"
                                                      GridLinesVisibility="None"
                                                      RowHeight="58"
                                                      MinRowHeight="58"
                                                      FontSize="12"
                                                      EnableRowVirtualization="True"
                                                      VirtualizingPanel.IsVirtualizing="True"
                                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                <DataGrid.Resources>
                                                    <Style x:Key="SclCatalogCellTextStyle" TargetType="TextBlock">
                                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                                        <Setter Property="TextTrimming" Value="None"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                        <Setter Property="LineStackingStrategy" Value="BlockLineHeight"/>
                                                        <Setter Property="LineHeight" Value="15"/>
                                                    </Style>
                                                    <Style x:Key="SclCatalogMetaTextStyle" TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#8FAAC3"/>
                                                        <Setter Property="FontSize" Value="10.5"/>
                                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                                        <Setter Property="LineHeight" Value="14"/>
                                                    </Style>
                                                </DataGrid.Resources>
                                                <DataGrid.Columns>
                                                    <DataGridTemplateColumn Header="Type" Width="64">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Border Background="#0D2A42" BorderBrush="#1F5D89" BorderThickness="1" CornerRadius="8" Padding="7,3" HorizontalAlignment="Left">
                                                                    <TextBlock Text="{Binding Protocol}" Foreground="#9FD8FF" FontSize="11" FontWeight="SemiBold"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="Stream / Control" Width="1.45*">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <StackPanel VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding DisplayName}" Foreground="#F4FAFF" FontWeight="SemiBold" Style="{StaticResource SclCatalogCellTextStyle}"/>
                                                                    <TextBlock Margin="0,3,0,0" Text="{Binding ControlBlockReference}" Style="{StaticResource SclCatalogMetaTextStyle}"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="Transport" Width="1.55*">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding TransportText}" Style="{StaticResource SclCatalogCellTextStyle}"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="DataSet" Width="1.6*">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding DataSetReference}" Style="{StaticResource SclCatalogCellTextStyle}"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="Entries" Width="82">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding EntryCountText}" Foreground="#CFE7FF" FontWeight="SemiBold" Style="{StaticResource SclCatalogCellTextStyle}"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="Live" Width="1.05*">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Border Background="#102438" BorderBrush="#244766" BorderThickness="1" CornerRadius="8" Padding="8,4" HorizontalAlignment="Left">
                                                                    <TextBlock Text="{Binding LiveStatusText}" Foreground="#EAF6FF" FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                </DataGrid.Columns>
                                            </DataGrid>

                                            <DockPanel Grid.Row="4">
                                                <StackPanel DockPanel.Dock="Left">
                                                    <TextBlock Text="Live Binding Matrix" Style="{StaticResource PanelTitleTextStyle}"/>
                                                    <TextBlock Margin="0,4,0,0"
                                                               Text="Expected SCL stream vs observed network traffic."
                                                               Foreground="#8FAAC3"
                                                               FontSize="11"/>
                                                </StackPanel>
                                                <Border HorizontalAlignment="Right"
                                                        VerticalAlignment="Top"
                                                        Background="#071A2B"
                                                        BorderBrush="#1F4E76"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Padding="10,5">
                                                    <TextBlock Text="{Binding SclBindingSummaryText}" Foreground="#F6D781" FontSize="11" FontWeight="SemiBold"/>
                                                </Border>
                                            </DockPanel>

                                            <DataGrid Grid.Row="6"
                                                      Style="{StaticResource DarkDataGridStyle}"
                                                      ItemsSource="{Binding SclFilteredBindingMatrix}"
                                                      SelectedItem="{Binding SelectedSclBindingMatrixRow, Mode=TwoWay}"
                                                      AutoGenerateColumns="False"
                                                      IsReadOnly="True"
                                                      HeadersVisibility="Column"
                                                      CanUserAddRows="False"
                                                      CanUserDeleteRows="False"
                                                      CanUserSortColumns="False"
                                                      GridLinesVisibility="None"
                                                      RowHeight="68"
                                                      MinRowHeight="68"
                                                      FontSize="11.5"
                                                      EnableRowVirtualization="True"
                                                      VirtualizingPanel.IsVirtualizing="True"
                                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                <DataGrid.Resources>
                                                    <Style x:Key="SclBindingCellTextStyle" TargetType="TextBlock">
                                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                                        <Setter Property="TextTrimming" Value="None"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                        <Setter Property="LineStackingStrategy" Value="BlockLineHeight"/>
                                                        <Setter Property="LineHeight" Value="15"/>
                                                    </Style>
                                                    <Style x:Key="SclBindingMetaTextStyle" TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#8FAAC3"/>
                                                        <Setter Property="FontSize" Value="10.5"/>
                                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                                        <Setter Property="LineHeight" Value="14"/>
                                                    </Style>
                                                </DataGrid.Resources>
                                                <DataGrid.Columns>
                                                    <DataGridTemplateColumn Header="Status" Width="118">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <StackPanel VerticalAlignment="Center">
                                                                    <Border Background="{Binding StatusBackgroundBrush}" BorderBrush="{Binding StatusBrush}" BorderThickness="1" CornerRadius="10" Padding="8,4" HorizontalAlignment="Left">
                                                                        <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusBrush}" FontSize="11" FontWeight="SemiBold"/>
                                                                    </Border>
                                                                    <TextBlock Margin="2,5,0,0" Text="{Binding ScoreText}" Style="{StaticResource SclBindingMetaTextStyle}"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="Type" Width="56">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Protocol}" Foreground="#9FD8FF" FontWeight="SemiBold" Style="{StaticResource SclBindingCellTextStyle}"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="Expected" Width="1.25*">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <StackPanel VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding ExpectedName}" Foreground="#F4FAFF" FontWeight="SemiBold" Style="{StaticResource SclBindingCellTextStyle}"/>
                                                                    <TextBlock Margin="0,4,0,0" Text="{Binding ExpectedMetaText}" Style="{StaticResource SclBindingMetaTextStyle}"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="Observed" Width="1.25*">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <StackPanel VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding ObservedName}" Foreground="#F6D781" FontWeight="SemiBold" Style="{StaticResource SclBindingCellTextStyle}"/>
                                                                    <TextBlock Margin="0,4,0,0" Text="{Binding ObservedMetaText}" Style="{StaticResource SclBindingMetaTextStyle}"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="Evidence" Width="2.15*">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <StackPanel VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding EvidencePrimaryText}" Foreground="#EAF6FF" FontWeight="SemiBold" Style="{StaticResource SclBindingCellTextStyle}"/>
                                                                    <TextBlock Margin="0,4,0,0" Text="{Binding EvidenceSecondaryText}" Style="{StaticResource SclBindingMetaTextStyle}"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Grid>
                                    </Border>

                                    <!-- Selected SCL object detail -->
                                    <Border Grid.Column="2" Style="{StaticResource DenseGroupBorderStyle}" Padding="16">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="12"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="12"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="Semantic Detail" Style="{StaticResource PanelTitleTextStyle}"/>
                                                <TextBlock Margin="0,4,0,0" Text="{Binding SclSelectedDetailTitle}" Foreground="#F4FAFF" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                <TextBlock Margin="0,5,0,0" Text="{Binding SclSelectedDetailSubtitle}" Foreground="#8FAAC3" FontSize="11.5" TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <Grid Grid.Row="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="10"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Style="{StaticResource DenseMetricCardStyle}" Padding="12">
                                                    <StackPanel>
                                                        <TextBlock Text="Expected" Foreground="#8FB8D8" FontSize="11" FontWeight="SemiBold"/>
                                                        <TextBlock Margin="0,6,0,0" Text="{Binding SclSelectedExpectedText}" Foreground="#EAF6FF" FontSize="12" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Column="2" Style="{StaticResource DenseMetricCardStyle}" Padding="12">
                                                    <StackPanel>
                                                        <TextBlock Text="Observed" Foreground="#8FB8D8" FontSize="11" FontWeight="SemiBold"/>
                                                        <TextBlock Margin="0,6,0,0" Text="{Binding SclSelectedObservedText}" Foreground="#F6D781" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <Border Grid.Row="4" Style="{StaticResource DenseMetricCardStyle}" Padding="12">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="10"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <DockPanel>
                                                        <TextBlock Text="DataSet Entry Order" Foreground="#F4FAFF" FontSize="13" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                                                        <TextBlock Text="Signal · FC · CDC · bType" Foreground="#8FAAC3" FontSize="11" HorizontalAlignment="Right"/>
                                                    </DockPanel>
                                                    <DataGrid Grid.Row="2"
                                                              Style="{StaticResource DarkDataGridStyle}"
                                                              ItemsSource="{Binding SclSelectedEntries}"
                                                              AutoGenerateColumns="False"
                                                              IsReadOnly="True"
                                                              HeadersVisibility="Column"
                                                              CanUserAddRows="False"
                                                              CanUserDeleteRows="False"
                                                              CanUserSortColumns="False"
                                                              GridLinesVisibility="None"
                                                              MinRowHeight="34"
                                                              FontSize="11.5"
                                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                        <DataGrid.Resources>
                                                            <Style x:Key="SclDetailCellTextStyle" TargetType="TextBlock">
                                                                <Setter Property="TextWrapping" Value="Wrap"/>
                                                                <Setter Property="TextTrimming" Value="None"/>
                                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                                <Setter Property="LineStackingStrategy" Value="BlockLineHeight"/>
                                                                <Setter Property="LineHeight" Value="15"/>
                                                            </Style>
                                                        </DataGrid.Resources>
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="40"/>
                                                            <DataGridTemplateColumn Header="Signal" Width="2.35*">
                                                                <DataGridTemplateColumn.CellTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock Text="{Binding DisplayName}" Style="{StaticResource SclDetailCellTextStyle}"/>
                                                                    </DataTemplate>
                                                                </DataGridTemplateColumn.CellTemplate>
                                                            </DataGridTemplateColumn>
                                                            <DataGridTextColumn Header="FC" Binding="{Binding Fc}" Width="0.55*"/>
                                                            <DataGridTextColumn Header="CDC" Binding="{Binding Cdc}" Width="0.75*"/>
                                                            <DataGridTextColumn Header="Type" Binding="{Binding BType}" Width="1.05*"/>
                                                        </DataGrid.Columns>
                                                    </DataGrid>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </TabItem>

                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0" Foreground="#EAF6FF" Text="&#xE713;"/>
                                    <TextBlock Text="Advanced" Foreground="#EAF6FF" FontWeight="SemiBold"/>
                                </StackPanel>
                            </TabItem.Header>
                            <Grid Margin="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="320"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource DenseGroupBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource PanelTitleTextStyle}" Text="{Binding AdvancedTargetTitle}"/>
                                        <TextBlock Margin="0,2,0,8" Style="{StaticResource PanelSubtitleTextStyle}" Text="{Binding AdvancedTargetSubtitle}"/>

                                        <Border Padding="10"
                                                Background="#081827"
                                                BorderBrush="#1B344F"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                            <TextBlock Text="{Binding AdvancedPrimaryDetailsText}"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource CompactValueTextStyle}"/>
                                        </Border>

                                        <Border Margin="0,10,0,0"
                                            Padding="8"
                                            Background="#0B1A2A"
                                            BorderBrush="#1B344F"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource PanelTitleTextStyle}" Text="{Binding AdvancedEvidenceTitle}"/>
                                                <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Style="{StaticResource CompactValueTextStyle}" Text="{Binding AdvancedPacketEvidenceText}"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Margin="0,10,0,0"
                                            Padding="8"
                                            Background="#0B1A2A"
                                            BorderBrush="#1B344F"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource PanelTitleTextStyle}" Text="{Binding AdvancedDecodedTitle}"/>
                                                <ScrollViewer Margin="0,6,0,0"
                                                          MaxHeight="92"
                                                          Style="{StaticResource ModernScrollViewerStyle}">
                                                    <TextBlock TextWrapping="Wrap" Style="{StaticResource CompactValueTextStyle}" Text="{Binding AdvancedRawValuesText}"/>
                                                </ScrollViewer>
                                            </StackPanel>
                                        </Border>

                                        <Border Margin="0,10,0,0"
                                            Padding="8"
                                            Background="#0B1A2A"
                                            BorderBrush="#1B344F"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource PanelTitleTextStyle}" Text="{Binding AdvancedEngineeringTitle}"/>
                                                <ScrollViewer Margin="0,6,0,0"
                                                          MaxHeight="112"
                                                          Style="{StaticResource ModernScrollViewerStyle}">
                                                    <StackPanel>
                                                        <TextBlock TextWrapping="Wrap" Style="{StaticResource CompactValueTextStyle}" Text="{Binding AdvancedEngineeringText}"/>
                                                    </StackPanel>
                                                </ScrollViewer>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource DenseGroupBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource PanelTitleTextStyle}" Text="Adapter and estimator"/>
                                        <TextBlock Margin="0,2,0,8" Style="{StaticResource PanelSubtitleTextStyle}" Text="Lab controls and live estimator state"/>

                                        <CheckBox Margin="0,0,0,8"
                                              Foreground="{StaticResource TextPrimaryBrush}"
                                              FontWeight="SemiBold"
                                              Content="Relax dest"
                                              IsChecked="{Binding RelaxDestinationCheck}"/>

                                        <WrapPanel>
                                            <Button Command="{Binding SwitchToRawCommand}"
                                                    IsEnabled="{Binding CanSwitchCaptureMode}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource HeaderButtonStyle}">
                                                        <Setter Property="Background" Value="#12263A"/>
                                                        <Setter Property="BorderBrush" Value="#294864"/>
                                                        <Setter Property="Foreground" Value="#CFE7FF"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRawMode}" Value="True">
                                                                <Setter Property="Background" Value="#0E6AC0"/>
                                                                <Setter Property="BorderBrush" Value="#6ED2FF"/>
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <TextBlock Text="Raw" FontWeight="SemiBold" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                            </Button>
                                        </WrapPanel>

                                        <Border Margin="0,10,0,0"
                                                Padding="8"
                                                Background="#0B1A2A"
                                                BorderBrush="#1B344F"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource PanelTitleTextStyle}" Text="SCL semantic map"/>
                                                <TextBlock Margin="0,5,0,0" TextWrapping="Wrap" Style="{StaticResource CompactValueTextStyle}" Text="{Binding SclSemanticStatusText}"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Margin="0,10,0,0"
                                            Padding="8"
                                            Background="#0B1A2A"
                                            BorderBrush="#1B344F"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource PanelTitleTextStyle}" Text="Estimator detail"/>
                                                <TextBlock Margin="0,6,0,0" Style="{StaticResource CompactValueTextStyle}" Text="{Binding Diagnostics.FrequencyReferenceChannel, StringFormat=Reference: {0}}"/>
                                                <TextBlock Margin="0,3,0,0" Style="{StaticResource CompactValueTextStyle}" Text="{Binding Diagnostics.FrequencyEstimateValid, StringFormat=Valid: {0}}"/>
                                                <TextBlock Margin="0,3,0,0" Style="{StaticResource CompactValueTextStyle}" Text="{Binding Diagnostics.FrequencyCrossingCount, StringFormat=Crossings: {0}}"/>
                                                <TextBlock Margin="0,3,0,0" Style="{StaticResource CompactValueTextStyle}" Text="{Binding Diagnostics.LastMeasuredPeriodMilliseconds, StringFormat=Last period: {0:0.###} ms}"/>
                                                <TextBlock Margin="0,3,0,0" Style="{StaticResource CompactValueTextStyle}" Text="{Binding Diagnostics.FrequencyInputSampleCount, StringFormat=Samples: {0}}"/>
                                                <TextBlock Margin="0,3,0,0" Style="{StaticResource CompactValueTextStyle}" Text="{Binding Diagnostics.TimebaseStatusText, StringFormat=Timebase: {0}}"/>
                                                <TextBlock Margin="0,3,0,0" Style="{StaticResource CompactValueTextStyle}" Text="{Binding Diagnostics.SmpSynchText, StringFormat=SmpSynch: {0}}"/>
                                                <TextBlock Margin="0,3,0,0" Style="{StaticResource CompactValueTextStyle}" Text="{Binding Diagnostics.ExpectedDeltaMicroseconds, StringFormat=Expected delta: {0:0.###} us}"/>
                                                <TextBlock Margin="0,3,0,0" Style="{StaticResource CompactValueTextStyle}" Text="{Binding Diagnostics.CurrentDeltaMicroseconds, StringFormat=Arrival delta: {0:0.###} us}"/>
                                                <TextBlock Margin="0,3,0,0" Style="{StaticResource CompactValueTextStyle}" Text="{Binding Diagnostics.CurrentJitterMicroseconds, StringFormat=Current variation: {0:0.###} us}"/>
                                                <TextBlock Margin="0,3,0,0" Style="{StaticResource CompactValueTextStyle}" Text="{Binding Diagnostics.MaxAbsJitterMicroseconds, StringFormat=Max abs variation: {0:0.###} us}"/>
                                                <TextBlock Margin="0,3,0,0" Style="{StaticResource CompactValueTextStyle}">
                                                    <Run Text="Excursions ≥300 us: "/>
                                                    <Run Text="{Binding Diagnostics.JitterOver300MicrosecondsCount}"/>
                                                </TextBlock>
                                                <TextBlock Margin="0,3,0,0" TextWrapping="Wrap" Style="{StaticResource CompactValueTextStyle}" Text="{Binding Diagnostics.JitterStatusText}"/>
                                                <TextBlock Margin="0,3,0,0" TextWrapping="Wrap" Style="{StaticResource MonoValueTextStyle}" Text="{Binding DebugEstimatorText, StringFormat=Reject: {0}}"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Margin="0,10,0,0"
                                            Padding="8"
                                            Background="#0B1A2A"
                                            BorderBrush="#1B344F"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource PanelTitleTextStyle}" Text="Performance"/>
                                                <TextBlock Margin="0,6,0,0" Style="{StaticResource CompactValueTextStyle}" Text="{Binding UiRefreshDurationText}"/>
                                                <TextBlock Margin="0,3,0,0" Style="{StaticResource CompactValueTextStyle}" Text="{Binding UiQueueDepthText}"/>
                                                <TextBlock Margin="0,3,0,0" Style="{StaticResource CompactValueTextStyle}" Text="{Binding ManagedMemoryText}"/>
                                                <TextBlock Margin="0,3,0,0" Style="{StaticResource CompactValueTextStyle}" Text="{Binding SkippedRefreshText}"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </TabItem>
                    </TabControl>

                    <Border HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0,22,0,0"
                            Padding="18,10"
                            CornerRadius="18"
                            Background="#CC0A1D2E"
                            BorderBrush="#446D9CC9"
                            BorderThickness="1"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE895;"
                                       Foreground="#70D7FF"
                                       FontSize="13"
                                       Margin="0,0,8,0"/>
                            <TextBlock Text="Preparing selected target view..."
                                       Foreground="#EAF6FF"
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </Grid>


                <Border Grid.Column="0"
                        Grid.ColumnSpan="5"
                        Grid.Row="2"
                        Padding="10,4"
                        Background="#0B1A2A"
                        BorderBrush="{StaticResource PanelBorderStrongBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <DockPanel LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   Foreground="#D6E8F8"
                                   Text="{Binding WorkspaceFooterLeftText}"/>
                        <TextBlock DockPanel.Dock="Right"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontWeight="SemiBold"
                                   Text="{Binding WorkspaceFooterRightText}"/>
                    </DockPanel>
                </Border>
            </Grid>
        </DockPanel>
    </Border>
</Window>
