                                                    <Setter TargetName="Track" Property="BorderBrush" Value="#1B8CFF"/>
                                                    <Setter TargetName="Knob" Property="Fill" Value="#F4FAFF"/>
                                                    <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right"/>
                                                    <Setter TargetName="Knob" Property="Margin" Value="0,0,3,0"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>

                                <StackPanel Grid.Row="2" Grid.ColumnSpan="2">
                                    <TextBlock Text="GOOSE ID"
                                               Foreground="#7FA8CC"
                                               FontSize="10.5"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,5"/>
                                    <ComboBox Style="{StaticResource CompactComboBoxStyle}"
                                              ItemsSource="{Binding GooseIdFilterOptions}"
                                              SelectedItem="{Binding SelectedGooseIdFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Grid.Row="3">
                                <TextBlock Text="Detected publishers"
                                           Foreground="#7FA8CC"
                                           FontSize="10.5"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>

                                <ListView ItemsSource="{Binding GooseMessages}"
                                          SelectedItem="{Binding SelectedGooseMessage, Mode=TwoWay}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,0,0,8"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListViewItem">
                                                        <Border x:Name="Card"
                                                                Padding="10,9"
                                                                Background="#071827"
                                                                BorderBrush="#16324E"
                                                                BorderThickness="1"
                                                                CornerRadius="10">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <ContentPresenter Grid.Column="0"/>
                                                                <TextBlock Grid.Column="1"
                                                                           Text="›"
                                                                           Foreground="#57B8FF"
                                                                           FontSize="18"
                                                                           VerticalAlignment="Center"
                                                                           Margin="8,0,0,0"/>
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="Card" Property="Background" Value="#0B3C68"/>
                                                                <Setter TargetName="Card" Property="BorderBrush" Value="#1387DF"/>
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Card" Property="BorderBrush" Value="#286592"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock Text="{Binding GoId}"
                                                           Foreground="#F4FAFF"
                                                           FontSize="12.5"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding GoCbRef}"
                                                           Foreground="#8FAAC3"
                                                           FontSize="10.5"
                                                           Margin="0,3,0,0"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Margin="0,5,0,0"
                                                           Foreground="#57B8FF"
                                                           FontSize="10.5"
                                                           TextTrimming="CharacterEllipsis">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0} · st/sq {1}/{2}">
                                                            <Binding Path="AppId"/>
                                                            <Binding Path="StNum"/>
                                                            <Binding Path="SqNum"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>

                            <Border Grid.Row="4"
                                    Padding="10,8"
                                    Background="#061522"
                                    BorderBrush="#132D46"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Margin="0,10,0,0">
                                <TextBlock Text="{Binding GooseFilterSummaryText}"
                                           Foreground="#8FAAC3"
                                           FontSize="10.5"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </Grid>

                        <!-- =========================================================
             TIMING / PTP LEFT EXPLORER
             ========================================================= -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedIndex, ElementName=WorkspaceTabs}" Value="3">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               FontSize="13"
                                               Margin="0,1,8,0"
                                               Foreground="{StaticResource AccentStrongBrush}"
                                               Text="&#xE916;"/>
                                    <TextBlock Style="{StaticResource PanelTitleTextStyle}"
                                               Text="Timing Reference"/>
                                </StackPanel>
                                <TextBlock Margin="0,2,0,10"
                                           Style="{StaticResource PanelSubtitleTextStyle}"
                                           Text="PTP context and timestamp confidence"/>
                            </StackPanel>

                            <Border Grid.Row="1" Style="{StaticResource DenseMetricCardStyle}" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="PTP Status" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Margin="0,8,0,0" Text="{Binding PtpStatusText}" Foreground="#EAF6FF" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                    <TextBlock Margin="0,5,0,0" Text="{Binding PtpTransportText}" Foreground="#8FAAC3" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Style="{StaticResource DenseMetricCardStyle}" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Timing Confidence" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Margin="0,8,0,0" Text="{Binding TimingConfidenceText}" Foreground="#F6D781" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="3" Style="{StaticResource DenseMetricCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Protocol Monitor" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Margin="0,8,0,0" Text="{Binding ProtocolSvStatusText}" Foreground="#EAF6FF" TextWrapping="Wrap"/>
                                    <TextBlock Margin="0,6,0,0" Text="{Binding ProtocolGooseStatusText}" Foreground="#EAF6FF" TextWrapping="Wrap"/>
                                    <TextBlock Margin="0,6,0,0" Text="{Binding ProtocolPtpStatusText}" Foreground="#EAF6FF" TextWrapping="Wrap"/>
                                    <Border Height="1" Background="#183B58" Margin="0,10,0,10"/>
                                    <TextBlock Text="{Binding TimingMetricText}" Foreground="#8FAAC3" TextWrapping="Wrap"/>
                                    <TextBlock Margin="0,8,0,0" Text="{Binding AdapterTimingRiskText}" Foreground="#8FAAC3" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- =========================================================
             SCL LEFT EXPLORER
             ========================================================= -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedIndex, ElementName=WorkspaceTabs}" Value="4">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               FontSize="13"
                                               Margin="0,1,8,0"
                                               Foreground="{StaticResource AccentStrongBrush}"
                                               Text="&#xE8D4;"/>
                                    <TextBlock Style="{StaticResource PanelTitleTextStyle}"
                                               Text="SCL Explorer"/>
                                </StackPanel>
                                <TextBlock Margin="0,2,0,10"
                                           Style="{StaticResource PanelSubtitleTextStyle}"
                                           Text="Imported IEDs from SCL documents. Select one IED to filter the semantic stream catalog."/>
                            </StackPanel>

                            <Border Grid.Row="1"
                                    Margin="0,0,0,10"
                                    Padding="10"
                                    Background="#0A1A2B"
                                    BorderBrush="#223B56"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <StackPanel>
                                    <TextBlock Text="Project summary"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding SclWorkspaceSummaryText}"
                                               TextWrapping="Wrap"
                                               Foreground="#8FAAC3"
                                               FontSize="10.5"/>
                                </StackPanel>
                            </Border>

                            <ListBox Grid.Row="2"
                                     ItemsSource="{Binding SclIedCards}"
                                     SelectedItem="{Binding SelectedSclIedCard, Mode=TwoWay}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,8"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="SclDocumentCard"
                                                            Padding="10,8"
                                                            Background="#0C1E2E"
                                                            BorderBrush="#1D3A55"
                                                            BorderThickness="1"
                                                            CornerRadius="9">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="SclDocumentCard" Property="Background" Value="#123E66"/>
                                                            <Setter TargetName="SclDocumentCard" Property="BorderBrush" Value="#1987E6"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="SclDocumentCard" Property="BorderBrush" Value="#2F6F9D"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" Foreground="#F3FAFF" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding SummaryText}" Foreground="#CFE7FF" FontSize="10.6" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding SourceFileName}" Foreground="#91AFC8" FontSize="10.2" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding StatusText}" Foreground="#6AD59F" FontSize="9.8" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <TextBlock Grid.Row="3"
                                       Text="Explorer selection drives the catalog and inspector."
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="10"/>
                        </Grid>

                        <!-- =========================================================
             FRAME VIEWER LEFT EXPLORER
             ========================================================= -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedIndex, ElementName=WorkspaceTabs}" Value="5">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               FontSize="13"
                               Margin="0,1,8,0"
                               Foreground="{StaticResource AccentStrongBrush}"
                               Text="&#xE713;"/>
                                    <TextBlock Style="{StaticResource PanelTitleTextStyle}"
                               Text="Advanced Tools"/>
                                </StackPanel>

                                <TextBlock Margin="0,2,0,10"
                           Style="{StaticResource PanelSubtitleTextStyle}"
                           Text="Debug-only tools"/>
                            </StackPanel>

                            <Border Grid.Row="1"
                                    Margin="0,0,0,10"
                                    Padding="10"
                                    Background="#0A1A2B"
                                    BorderBrush="#223B56"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <StackPanel>
                                    <TextBlock Text="SCL Semantic Mapping"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Margin="0,4,0,8"
                                               Text="{Binding SclSummaryText}"
                                               TextWrapping="Wrap"
                                               Foreground="#8FAAC3"
                                               FontSize="10.5"/>
                                    <WrapPanel>
                                        <Button Command="{Binding LoadSclCommand}"
                                                Style="{StaticResource ToolbarGhostButtonStyle}"
                                                MinWidth="72"
                                                Padding="10,5">
                                            <TextBlock Text="Load SCL" FontWeight="SemiBold"/>
                                        </Button>
                                        <Button Command="{Binding ClearSclCommand}"
                                                Style="{StaticResource ToolbarMutedButtonStyle}"
                                                MinWidth="56"
                                                Padding="10,5"
                                                Margin="6,0,0,0">
                                            <TextBlock Text="Clear" FontWeight="SemiBold"/>
                                        </Button>
                                    </WrapPanel>
                                    <TextBlock Margin="0,7,0,0"
                                               Text="{Binding SclLoadStatusText}"
                                               TextWrapping="Wrap"
                                               Foreground="#6F8FAF"
                                               FontSize="10"/>
                                </StackPanel>
                            </Border>

                            <Grid Grid.Row="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Style="{StaticResource DenseMetricCardStyle}" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="Raw Target Explorer"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="Select SV, GOOSE, or PTP source. Details stay locked while live data updates."
                                                   TextWrapping="Wrap"
                                                   Foreground="#8FAAC3"
                                                   FontSize="10.5"/>
                                    </StackPanel>
                                </Border>
                                <ListBox Grid.Row="1"
                                         ItemsSource="{Binding DiagnosticTargets}"
                                         SelectedItem="{Binding SelectedDiagnosticTarget, Mode=TwoWay}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,0,0,8"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="AdvancedTargetCard"
                                                                Padding="10,8"
                                                                Background="#0C1E2E"
                                                                BorderBrush="#1D3A55"
                                                                BorderThickness="1"
                                                                CornerRadius="9">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="AdvancedTargetCard" Property="Background" Value="#123E66"/>
                                                                <Setter TargetName="AdvancedTargetCard" Property="BorderBrush" Value="#1987E6"/>
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="AdvancedTargetCard" Property="BorderBrush" Value="#2F6F9D"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="5" CornerRadius="3" Margin="0,1,8,1" Background="{Binding StatusBrush}"/>
                                                <StackPanel Grid.Column="1">
                                                    <DockPanel LastChildFill="True">
                                                        <TextBlock DockPanel.Dock="Left" Text="{Binding Protocol}" Foreground="#8FB8D8" FontSize="10" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                                        <TextBlock Text="{Binding DisplayName}" Foreground="#F3FAFF" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                    </DockPanel>
                                                    <TextBlock Text="{Binding Subtitle}" Foreground="#91AFC8" FontSize="10.3" TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/>
                                                    <TextBlock Text="{Binding LastSeenText}" Foreground="#789AB8" FontSize="9.5" Margin="0,3,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>

                            <TextBlock Grid.Row="3"
                       Text="Advanced raw decode only."
                       TextWrapping="Wrap"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="10"/>
                        </Grid>
                    </Grid>
                </Border>

                <Grid Grid.Column="2"
            Grid.ColumnSpan="3"
            Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TabControl x:Name="WorkspaceTabs"
                        Grid.Row="0"
                                SelectedIndex="{Binding CurrentWorkspaceTabIndex, Mode=TwoWay}"
                                SelectionChanged="WorkspaceTabs_SelectionChanged"
                            Style="{StaticResource AnalyzerTabControlStyle}">
                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </Style>
                        </TabControl.Resources>

                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0" Foreground="#EAF6FF" Text="&#xE9D9;"/>
                                    <TextBlock Text="Analyzer" Foreground="#EAF6FF" FontWeight="SemiBold"/>
                                </StackPanel>
                            </TabItem.Header>
                            <Grid Margin="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="320"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Column="0"
            Grid.Row="0"
            Style="{StaticResource DenseGroupBorderStyle}"
            Padding="8">
                                    <WrapPanel>
                                        <Border Style="{StaticResource MetricChipBorderStyle}">
                                            <TextBlock Foreground="{StaticResource AccentBrush}"
                           FontWeight="SemiBold"
                           Text="{Binding WaveformHeaderFrequencyText}"/>
                                        </Border>
                                        <Border Style="{StaticResource MetricChipBorderStyle}">
                                            <TextBlock Foreground="{StaticResource AccentBrush}"
                           FontWeight="SemiBold"
                           Text="{Binding WaveformHeaderSamplesPerCycleText}"/>
                                        </Border>
                                        <Border Style="{StaticResource MetricChipBorderStyle}">
                                            <TextBlock Foreground="{StaticResource AccentBrush}"
                           FontWeight="SemiBold"
                           Text="{Binding WaveformHeaderWindowText}"/>
                                        </Border>
                                        <Border Style="{StaticResource MetricChipBorderStyle}">
                                            <TextBlock Foreground="{StaticResource AccentBrush}"
                           FontWeight="SemiBold"
                           Text="Reference: Ua"/>
                                        </Border>
                                    </WrapPanel>
                                </Border>

                                <Border x:Name="ScopeHeroPanel"
            Grid.Column="0"
            Grid.Row="2"
            Style="{StaticResource DenseGroupBorderStyle}"
            BorderBrush="#0D8CFF"
            BorderThickness="1.2"
            Background="#0B2035">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#0D8CFF"
                                                          BlurRadius="18"
                                                          ShadowDepth="0"
                                                          Opacity="0.22"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- Live animation feel: subtle animated blue wash only while capture is running -->
                                        <Border Grid.RowSpan="3"
                                                CornerRadius="11"
                                                IsHitTestVisible="False">
                                            <Border.Background>
                                                <RadialGradientBrush RadiusX="0.85" RadiusY="0.65" Center="0.50,0.20" GradientOrigin="0.50,0.20">
                                                    <GradientStop Color="#2A8CFF" Offset="0"/>
                                                    <GradientStop Color="#001B33" Offset="0.72"/>
                                                    <GradientStop Color="#000000" Offset="1"/>
                                                </RadialGradientBrush>
                                            </Border.Background>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Opacity" Value="0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard x:Name="ScopeLivePulseStoryboard">
                                                                    <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                         From="0.05" To="0.18"
                                                                                         Duration="0:0:1.35"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                            <DataTrigger.ExitActions>
                                                                <RemoveStoryboard BeginStoryboardName="ScopeLivePulseStoryboard"/>
                                                            </DataTrigger.ExitActions>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>


                                        <DockPanel Margin="0,0,0,8" LastChildFill="False">
                                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,1,8,0" Foreground="{StaticResource AccentStrongBrush}" Text="&#xE9D9;"/>
                                                <TextBlock Style="{StaticResource PanelTitleTextStyle}" Text="SV-Scope (IEC 61850 Digital Oscilloscope)"/>
                                            </StackPanel>
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                <Border Padding="7,2"
                                                        Margin="0,0,8,0"
                                                        Background="#0D8CFF"
                                                        CornerRadius="10">
                                                    <TextBlock Text="FOCUS"
                                                               FontSize="9"
                                                               FontWeight="Bold"
                                                               Foreground="White"/>
                                                </Border>

                                                <Border Padding="7,2"
                                                        Margin="0,0,8,0"
                                                        Background="#0B2A1F"
                                                        BorderBrush="#2AFF9C"
                                                        BorderThickness="1"
                                                        CornerRadius="10">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Ellipse Width="6" Height="6" Fill="#2AFF9C" Margin="0,0,5,0" VerticalAlignment="Center">
                                                            <Ellipse.Style>
                                                                <Style TargetType="Ellipse">
                                                                    <Setter Property="Opacity" Value="0.55"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                            <DataTrigger.EnterActions>
                                                                                <BeginStoryboard x:Name="LiveDotPulseStoryboard">
                                                                                    <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                                                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                                         From="0.45" To="1"
                                                                                                         Duration="0:0:0.75"/>
                                                                                    </Storyboard>
                                                                                </BeginStoryboard>
                                                                            </DataTrigger.EnterActions>
                                                                            <DataTrigger.ExitActions>
                                                                                <RemoveStoryboard BeginStoryboardName="LiveDotPulseStoryboard"/>
