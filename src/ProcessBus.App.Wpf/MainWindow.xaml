<Window x:Class="ProcessBus.App.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:ProcessBus.App.Wpf.Controls"
        xmlns:vm="clr-namespace:ProcessBus.App.Wpf.ViewModels"
        xmlns:conv="clr-namespace:ProcessBus.App.Wpf.Converters"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:MainWindowViewModel, IsDesignTimeCreatable=True}"
        Title="Process Bus Insight - IEC 61850 Analyzer"
        Width="1600"
        Height="900"
        MinWidth="1240"
        MinHeight="760"
        Background="#07111D"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType" Icon="/IEC61850.PNG">

    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <Window.Resources>
        <conv:GooseEventBgConverter x:Key="EventBgConverter"/>
        <conv:GooseEventFgConverter x:Key="EventFgConverter"/>
    </Window.Resources>

    <Border Background="{StaticResource ShellBackgroundBrush}">
        <DockPanel Margin="8">

            <Border DockPanel.Dock="Top"
        Margin="0,0,0,8"
        Padding="0"
        Background="{StaticResource PremiumHeaderBrush}"
        Effect="{StaticResource CardShadow}"
        BorderBrush="{StaticResource PanelBorderStrongBrush}"
        BorderThickness="1"
        CornerRadius="8">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- =========================================================
             ROW 0 — PRODUCT IDENTITY + WORKSPACE TABS
             ========================================================= -->
                    <Border Grid.Row="0"
                Padding="12,6"
                Background="#0A1726"
                BorderBrush="#1C3854"
                BorderThickness="0,0,0,1"
                CornerRadius="8,8,0,0">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Product identity -->
                            <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                                <Border Width="38"
                            Height="38"
                            CornerRadius="8"
                            Background="#102A43"
                            BorderBrush="#26577D"
                            BorderThickness="1"
                            Margin="0,0,10,0">
                                    <Image Source="/Views/Assets/Icons/IEC61850.PNG"
                               Stretch="Uniform"
                               Margin="5"/>
                                </Border>

                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Process Bus Insight"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>

                                    <TextBlock Text="IEC 61850 SV / GOOSE / PTP Workspace"
                                   Margin="0,2,0,0"
                                   FontSize="11"
                                   Foreground="#7FA8CC"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Workspace selector: web-modern segmented control / Blue Pill Effect -->
                            <Border Grid.Column="2"
                                    Style="{StaticResource WorkspaceSegmentHostStyle}"
                                    HorizontalAlignment="center"
                                    VerticalAlignment="Center">
                                <Grid x:Name="WorkspaceSegmentRail"
                                      ClipToBounds="True">
                                    <Border x:Name="WorkspaceActivePill"
                                            Width="136"
                                            Height="38"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            CornerRadius="20"
                                            IsHitTestVisible="False">
                                        <Border.RenderTransform>
                                            <TranslateTransform x:Name="WorkspaceActivePillTransform"/>
                                        </Border.RenderTransform>
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#1189FF" Offset="0"/>
                                                <GradientStop Color="#0A5FB8" Offset="0.55"/>
                                                <GradientStop Color="#073A7A" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.Effect>
                                            <DropShadowEffect Color="#1B8CFF" BlurRadius="18" ShadowDepth="0" Opacity="0.45"/>
                                        </Border.Effect>
                                    </Border>

                                    <StackPanel x:Name="WorkspaceSegmentButtons"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">

                                <RadioButton x:Name="AnalyzerWorkspaceButton"
                                             GroupName="WorkspaceTabs"
                                 Style="{StaticResource AnalyzerTabButtonStyle}"
                                 IsChecked="True"
                                 Tag="0"
                                 Click="WorkspaceTabButton_Click">
                                    <StackPanel Orientation="Horizontal" IsHitTestVisible="False">
                                        <Viewbox Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center">
                                            <Path Style="{StaticResource NavVectorIconStyle}" Data="{StaticResource IconAnalyzerGeometry}"/>
                                        </Viewbox>
                                        <TextBlock Text="Analyzer"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                    </StackPanel>
                                </RadioButton>

                                <RadioButton x:Name="DiagnosticsWorkspaceButton"
                                             GroupName="WorkspaceTabs"
                                 Style="{StaticResource AnalyzerTabButtonStyle}"
                                 Tag="1"
                                 Click="WorkspaceTabButton_Click">
                                    <StackPanel Orientation="Horizontal" IsHitTestVisible="False">
                                        <Viewbox Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center">
                                            <Path Style="{StaticResource NavVectorIconStyle}" Data="{StaticResource IconDiagnosticsGeometry}"/>
                                        </Viewbox>
                                        <TextBlock Text="Diagnostics"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                    </StackPanel>
                                </RadioButton>

                                <RadioButton x:Name="GooseWorkspaceButton"
                                             GroupName="WorkspaceTabs"
                                 Style="{StaticResource AnalyzerTabButtonStyle}"
                                 Tag="2"
                                 Click="WorkspaceTabButton_Click">
                                    <StackPanel Orientation="Horizontal" IsHitTestVisible="False">
                                        <Viewbox Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center">
                                            <Path Style="{StaticResource NavVectorIconStyle}" Data="{StaticResource IconGooseGeometry}"/>
                                        </Viewbox>
                                        <TextBlock Text="GOOSE"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                    </StackPanel>
                                </RadioButton>

                                <RadioButton x:Name="TimingWorkspaceButton"
                                             GroupName="WorkspaceTabs"
                                 Style="{StaticResource AnalyzerTabButtonStyle}"
                                 Tag="3"
                                 Click="WorkspaceTabButton_Click">
                                    <StackPanel Orientation="Horizontal" IsHitTestVisible="False">
                                        <Viewbox Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center">
                                            <Path Style="{StaticResource NavVectorIconStyle}" Data="{StaticResource IconDiagnosticsGeometry}"/>
                                        </Viewbox>
                                        <TextBlock Text="Timing/PTP"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                    </StackPanel>
                                </RadioButton>

                                <RadioButton x:Name="SclWorkspaceButton"
                                             GroupName="WorkspaceTabs"
                                 Style="{StaticResource AnalyzerTabButtonStyle}"
                                 Tag="4"
                                 Click="WorkspaceTabButton_Click">
                                    <StackPanel Orientation="Horizontal" IsHitTestVisible="False">
                                        <Viewbox Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center">
                                            <Path Style="{StaticResource NavVectorIconStyle}" Data="{StaticResource IconFramesGeometry}"/>
                                        </Viewbox>
                                        <TextBlock Text="SCL"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                    </StackPanel>
                                </RadioButton>

                                <RadioButton x:Name="FramesWorkspaceButton"
                                             GroupName="WorkspaceTabs"
                                 Style="{StaticResource AnalyzerTabButtonStyle}"
                                 Tag="5"
                                 Click="WorkspaceTabButton_Click">
                                    <StackPanel Orientation="Horizontal" IsHitTestVisible="False">
                                        <Viewbox Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center">
                                            <Path Style="{StaticResource NavVectorIconStyle}" Data="{StaticResource IconFramesGeometry}"/>
                                        </Viewbox>
                                        <TextBlock Text="Advanced"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                    </StackPanel>
                                </RadioButton>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Global capture controls: adapter + run/stop/clear live in the most actionable header area. -->
                            <StackPanel Grid.Column="3"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Right">

                                <ComboBox Width="300"
                                          Style="{StaticResource ToolbarAdapterComboBoxStyle}"
                                          IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"
                                          ItemsSource="{Binding Adapters}"
                                          SelectedValuePath="Id"
                                          SelectedValue="{Binding SelectedAdapterId, UpdateSourceTrigger=PropertyChanged}"
                                          ToolTip="Select capture adapter"/>

                                <Button Margin="8,0,0,0"
                                        Command="{Binding StartCommand}"
                                        ToolTipService.InitialShowDelay="180">
                                    <Button.ToolTip>
                                        <ToolTip Style="{StaticResource GlassToolTipStyle}" Content="Start live SV/GOOSE/PTP capture"/>
                                    </Button.ToolTip>
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource HeroToolbarButtonStyle}">
                                            <Setter Property="MinWidth" Value="82"/>
                                            <Setter Property="Height" Value="34"/>
                                            <Setter Property="Padding" Value="12,0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                    <Setter Property="Background" Value="#12263A"/>
                                                    <Setter Property="BorderBrush" Value="#294864"/>
                                                    <Setter Property="Foreground" Value="#8FA8BF"/>
                                                    <Setter Property="Opacity" Value="0.72"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <Viewbox Width="12" Height="12" Margin="0,0,7,0" VerticalAlignment="Center">
                                            <Path Style="{StaticResource ToolbarVectorIconStyle}" Data="{StaticResource IconPlayGeometry}"/>
                                        </Viewbox>
                                        <TextBlock Text="Run"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    </StackPanel>
                                </Button>

                                <Button Margin="6,0,0,0"
                                        Command="{Binding StopCommand}"
                                        ToolTipService.InitialShowDelay="180">
                                    <Button.ToolTip>
                                        <ToolTip Style="{StaticResource GlassToolTipStyle}" Content="Stop current capture session"/>
                                    </Button.ToolTip>
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource DangerToolbarButtonStyle}">
                                            <Setter Property="MinWidth" Value="82"/>
                                            <Setter Property="Height" Value="34"/>
                                            <Setter Property="Padding" Value="12,0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                    <Setter Property="Background" Value="#0E6AC0"/>
                                                    <Setter Property="BorderBrush" Value="#6ED2FF"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <Viewbox Width="11" Height="11" Margin="0,0,7,0" VerticalAlignment="Center">
                                            <Path Style="{StaticResource ToolbarVectorIconStyle}" Data="{StaticResource IconStopGeometry}"/>
                                        </Viewbox>
                                        <TextBlock Text="Stop"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    </StackPanel>
                                </Button>

                                <Button Command="{Binding ClearCommand}"
                                        ToolTipService.InitialShowDelay="180">
                                    <Button.ToolTip>
                                        <ToolTip Style="{StaticResource GlassToolTipStyle}" Content="Clear current session"/>
                                    </Button.ToolTip>
                                    <Button.Content>
                                        <Viewbox Width="14" Height="14" VerticalAlignment="Center">
                                            <Path Style="{StaticResource ToolbarVectorIconStyle}" Data="{StaticResource IconClearGeometry}"/>
                                        </Viewbox>
                                    </Button.Content>
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource CircleToolbarButtonStyle}">
                                            <Setter Property="Width" Value="34"/>
                                            <Setter Property="Height" Value="34"/>
                                            <Setter Property="Margin" Value="6,0,0,0"/>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Style="{StaticResource HeaderCircleButtonStyle}"
                                        Width="34"
                                        Height="34"
                                        Margin="8,0,0,0"
                                        Click="About_Click">
                                    <Button.ToolTip>
                                        <ToolTip Style="{StaticResource GlassToolTipStyle}" Content="About this instrument"/>
                                    </Button.ToolTip>
                                    <Viewbox Width="14" Height="14" VerticalAlignment="Center">
                                        <Path Style="{StaticResource ToolbarVectorIconStyle}" Data="{StaticResource IconInfoGeometry}"/>
                                    </Viewbox>
                                </Button>
                            </StackPanel>                        </Grid>
                    </Border>

                    <!-- =========================================================
             ROW 1 — CONTEXT TOOLBAR
             Toolbar berubah sesuai workspace aktif
             ========================================================= -->
                    <Border Grid.Row="1"
                Height="0"
                Visibility="Collapsed"
                Padding="12,0"
                Background="#081522"
                BorderBrush="#1C3854"
                BorderThickness="0,0,0,1">

                        <Grid>

                            <!-- ANALYZER TOOLBAR -->
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentWorkspaceTabIndex}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                                    <TextBlock Text="Capture"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="#7FBCEB"/>

                                    <TextBlock Text="Adapter"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource PanelSubtitleTextStyle}"/>

                                    <ComboBox Style="{StaticResource ToolbarAdapterComboBoxStyle}"
                                  IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"
                                  ItemsSource="{Binding Adapters}"
                                  SelectedValuePath="Id"
                                  SelectedValue="{Binding SelectedAdapterId, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <Border Grid.Column="1"
                            Width="1"
                            Margin="0,2"
                            Background="#1C3854"/>

                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">

                                    <!-- Primary action stays readable: icon + label -->
                                    <Button x:Name="StartCaptureButton"
                                            Command="{Binding StartCommand}"
                                            ToolTipService.InitialShowDelay="180">
                                        <Button.ToolTip>
                                            <ToolTip Style="{StaticResource GlassToolTipStyle}" Content="Start live SV/GOOSE/PTP capture"/>
                                        </Button.ToolTip>
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource HeroToolbarButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                        <Setter Property="Background" Value="#12263A"/>
                                                        <Setter Property="BorderBrush" Value="#294864"/>
                                                        <Setter Property="Foreground" Value="#8FA8BF"/>
                                                        <Setter Property="Opacity" Value="0.72"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <Viewbox Width="13" Height="13" Margin="0,0,8,0" VerticalAlignment="Center">
                                                <Path Style="{StaticResource ToolbarVectorIconStyle}" Data="{StaticResource IconPlayGeometry}"/>
                                            </Viewbox>
                                            <TextBlock Text="Start"
                                                       FontWeight="SemiBold"
                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Stop is still labeled: safety/action clarity -->
                                    <Button Margin="6,0,0,0"
                                            Command="{Binding StopCommand}"
                                            ToolTipService.InitialShowDelay="180">
                                        <Button.ToolTip>
                                            <ToolTip Style="{StaticResource GlassToolTipStyle}" Content="Stop current capture session"/>
                                        </Button.ToolTip>
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource DangerToolbarButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                        <Setter Property="Background" Value="#0E6AC0"/>
                                                        <Setter Property="BorderBrush" Value="#6ED2FF"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <Viewbox Width="12" Height="12" Margin="0,0,8,0" VerticalAlignment="Center">
                                                <Path Style="{StaticResource ToolbarVectorIconStyle}" Data="{StaticResource IconStopGeometry}"/>
                                            </Viewbox>
                                            <TextBlock Text="Stop"
                                                       FontWeight="SemiBold"
                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Secondary utilities become satisfying circular icon buttons -->
                                    <Button Command="{Binding ClearCommand}">
                                        <Button.ToolTip>
                                            <ToolTip Style="{StaticResource GlassToolTipStyle}" Content="Clear current waveform and logs"/>
                                        </Button.ToolTip>
                                        <Button.Content>
                                            <Viewbox Width="15" Height="15" VerticalAlignment="Center">
                                                <Path Style="{StaticResource ToolbarVectorIconStyle}" Data="{StaticResource IconClearGeometry}"/>
                                            </Viewbox>
                                        </Button.Content>
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource CircleToolbarButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                        <Setter Property="Opacity" Value="0.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <Button Style="{StaticResource CircleToolbarButtonStyle}"
                                            Tag="Record / Replay"
                                            Visibility="Collapsed"
                                            Click="LockedFeature_Click">
                                        <Button.ToolTip>
                                            <ToolTip Style="{StaticResource GlassToolTipStyle}" Content="Record / replay session — planned engineering workflow"/>
                                        </Button.ToolTip>
                                        <Grid Width="16" Height="16">
                                            <Ellipse Width="9"
                                                     Height="9"
                                                     Fill="{StaticResource DangerBrush}"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>
                                </StackPanel>

                                <Border Grid.Column="3"
                            Width="1"
                            Margin="0,2"
                            Background="#1C3854"/>

                                <Border Grid.Column="5"
                                        Padding="8,4"
                                        CornerRadius="22"
                                        BorderBrush="#1E3A54"
                                        Visibility="Collapsed"
                                        BorderThickness="1">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#0B1725" Offset="0"/>
                                            <GradientStop Color="#081522" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>

                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Project"
                                                   Margin="4,0,6,0"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   Foreground="#7FBCEB"/>

                                        <Button Style="{StaticResource ProjectCircleButtonStyle}"
                                                Tag="New Project"
                                                Click="LockedFeature_Click">
                                            <Button.ToolTip>
                                                <ToolTip Style="{StaticResource GlassToolTipStyle}" Content="New project"/>
                                            </Button.ToolTip>
                                            <Viewbox Width="14" Height="14" VerticalAlignment="Center">
                                                <Path Style="{StaticResource ToolbarVectorIconStyle}" Data="{StaticResource IconNewGeometry}"/>
                                            </Viewbox>
                                        </Button>

                                        <Button Style="{StaticResource ProjectCircleButtonStyle}"
                                                Tag="Import SCD / CID / ICD"
                                                Click="LockedFeature_Click">
                                            <Button.ToolTip>
                                                <ToolTip Style="{StaticResource GlassToolTipStyle}" Content="Import SCD / CID / ICD"/>
                                            </Button.ToolTip>
                                            <Viewbox Width="14" Height="14" VerticalAlignment="Center">
                                                <Path Style="{StaticResource ToolbarVectorIconStyle}" Data="{StaticResource IconImportGeometry}"/>
                                            </Viewbox>
                                        </Button>

                                        <Button Style="{StaticResource ProjectCircleButtonStyle}"
                                                Tag="Report Center"
                                                Click="LockedFeature_Click">
                                            <Button.ToolTip>
                                                <ToolTip Style="{StaticResource GlassToolTipStyle}" Content="Open report center"/>
                                            </Button.ToolTip>
                                            <Viewbox Width="14" Height="14" VerticalAlignment="Center">
                                                <Path Style="{StaticResource ToolbarVectorIconStyle}" Data="{StaticResource IconReportGeometry}"/>
                                            </Viewbox>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- DIAGNOSTICS TOOLBAR -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentWorkspaceTabIndex}" Value="1">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <TextBlock Text="Diagnostics"
                               Margin="0,0,10,0"
                               VerticalAlignment="Center"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#7FBCEB"/>

                                <Button Style="{StaticResource ToolbarGhostButtonStyle}"
                            Command="{Binding ClearCommand}">
                                    <TextBlock Text="Reset Stats"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </Button>

                                <Button Style="{StaticResource ToolbarGhostButtonStyle}"
                            Margin="6,0,0,0"
                            Tag="Diagnostic Bundle"
                            Visibility="Collapsed"
                            Click="LockedFeature_Click">
                                    <TextBlock Text="Export Bundle"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </Button>

                                <Button Style="{StaticResource ToolbarGhostButtonStyle}"
                            Margin="6,0,0,0"
                            Tag="PTP Monitor"
                            Visibility="Collapsed"
                            Click="LockedFeature_Click">
                                    <TextBlock Text="PTP Sync"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </Button>
                            </StackPanel>

                            <!-- GOOSE TOOLBAR -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentWorkspaceTabIndex}" Value="2">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <TextBlock Text="GOOSE"
                               Margin="0,0,10,0"
                               VerticalAlignment="Center"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#7FBCEB"/>

                                <Button Style="{StaticResource ToolbarGhostButtonStyle}"
                            Tag="GOOSE APPID Filter"
                            Visibility="Collapsed"
                            Click="LockedFeature_Click">
                                    <TextBlock Text="Filter APPID"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </Button>

                                <Button Style="{StaticResource ToolbarGhostButtonStyle}"
                            Margin="6,0,0,0"
                            Tag="GOOSE Event Export"
                            Visibility="Collapsed"
                            Click="LockedFeature_Click">
                                    <TextBlock Text="Export Events"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </Button>

                                <Button Style="{StaticResource ToolbarGhostButtonStyle}"
                            Margin="6,0,0,0"
                            Tag="SCL/SCD Mapping"
                            Visibility="Collapsed"
                            Click="LockedFeature_Click">
                                    <TextBlock Text="Dataset Mapping"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </Button>
                            </StackPanel>

                            <!-- FRAME VIEWER TOOLBAR -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentWorkspaceTabIndex}" Value="5">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <TextBlock Text="Advanced"
                               Margin="0,0,10,0"
                               VerticalAlignment="Center"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#7FBCEB"/>

                                <Button Style="{StaticResource ToolbarGhostButtonStyle}"
