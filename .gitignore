################################################################################
# Source repository hygiene
################################################################################

# IDE / editor state
.vs/
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.rsuser
*.swp
*.tmp

# Build outputs
bin/
obj/
**/bin/
**/obj/
out/
artifacts/
installer/
publish/
release/

# .NET local state and packages
.dotnet/
.dotnet-cli/
.dotnet-home/
.dotnet-home-build/
*.nupkg
*.snupkg
TestResults/
coverage/
coverage.*
*.trx

# Native / Visual C++ generated files
*.ipch
*.iobj
*.ipdb
*.pdb
*.ilk
*.idb
*.tlog
*.lastbuildstate
*.recipe
Browse.VC.db*
Solution.VC.db*
UpgradeLog*.htm

# Runtime binaries and generated app outputs
*.dll
*.exe
*.deps.json
*.runtimeconfig.json
*.cache
*.log

# Local configuration / secrets
.env
.env.*
*.pfx
*.snk
secrets.json
appsettings.Development.json

# Local capture/runtime state
*.last_interface.txt
*.pcap
*.pcapng
*.etl
captures/
logs/
temp/
tmp/

# Local generated reports/media
*.pdf
!docs/QUICK_START.pdf
!docs/USER_MANUAL.pdf
*.gif
docs/screenshot/*.png
docs/pdf_renders/
docs/_renders/

# Node/web outputs if a future site toolchain is added
node_modules/
dist/
build/
.parcel-cache/
.vite/

# Local automation/browser state
.codex/
.playwright/
